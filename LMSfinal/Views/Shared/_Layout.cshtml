<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <partial name="_SeoMeta" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/color-scheme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing-pages.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-mortarboard-fill me-1"></i> LMS Academy
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Courses" asp-action="Index">Khóa học</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Categories" asp-action="Index">Danh mục</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Contact" asp-action="Index">Liên hệ</a></li>

                </ul>
                <div class="d-flex gap-2 align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="text-white-50 small d-none d-md-inline">@User.Identity.Name</span>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="btn btn-outline-light btn-sm" asp-area="Admin" asp-controller="HomeAdmin" asp-action="index">Trang admin</a></li>
                        }
                        @if (User.IsInRole("Instructor"))
                        {
                            <li class="nav-item"><a class="btn btn-outline-light btn-sm" asp-area="Instructor" asp-controller="HomeInstructor" asp-action="index">Trang giảng viên</a></li>
                        }
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item"><a class="btn btn-outline-light btn-sm" asp-area="Student" asp-controller="Home" asp-action="index">Trang học viên</a></li>
                        }
                        <a class="btn btn-outline-light btn-sm" asp-area="Student" asp-controller="Dashboard" asp-action="Index">Học tập</a>
                        
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-dark text-light py-5 mt-auto">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-bold"><i class="bi bi-mortarboard-fill"></i> LMS Academy</h5>
                    <p class="text-secondary small">Nền tảng học tập trực tuyến – phát triển kỹ năng cho tương lai.</p>
                </div>
                <div class="col-md-2">
                    <h6 class="text-uppercase small fw-bold">Khám phá</h6>
                    <ul class="list-unstyled small">
                        <li><a class="text-secondary text-decoration-none" asp-controller="Courses" asp-action="Index">Khóa học</a></li>
                        <li><a class="text-secondary text-decoration-none" asp-controller="Categories" asp-action="Index">Danh mục</a></li>
                    </ul>
                </div>
                <div class="col-md-2">
                    <h6 class="text-uppercase small fw-bold">Hỗ trợ</h6>
                    <ul class="list-unstyled small">
                        <li><a class="text-secondary text-decoration-none" asp-controller="Contact" asp-action="Index">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase small fw-bold">Đăng ký tư vấn</h6>
                    <p class="text-secondary small mb-2">Nhận thông tin khóa học mới nhất</p>
                    <a class="btn btn-primary btn-sm" asp-controller="Contact" asp-action="Index">Liên hệ ngay</a>
                </div>
            </div>
            <hr class="border-secondary my-4" />
            <p class="text-center text-secondary small mb-0">&copy; @DateTime.Now.Year LMS Academy. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
