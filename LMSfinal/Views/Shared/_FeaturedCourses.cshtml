@using LMSfinal.Models.EF
@model List<Course>

<section class="featured-courses py-5 bg-light">
    <div class="container">
        <div class="row mb-4">
            <div class="col-lg-8">
                <h2 class="display-6 fw-bold mb-2">Khóa học nổi bật</h2>
                <p class="text-muted lead">Những khóa học được yêu thích nhất trên nền tảng</p>
            </div>
            <div class="col-lg-4 text-end">
                <a href="/courses" class="btn btn-outline-primary">
                    Xem tất cả <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var course in Model.Take(6))
                {
                    <div class="col-lg-4 col-md-6 col-sm-12">
                        <div class="card featured-course-card h-100 shadow-sm border-0 overflow-hidden">
                            <!-- Image Container -->
                            <div class="position-relative overflow-hidden" style="height: 220px;">
                                <img src="@(course.ImageUrl ?? "/images/course-placeholder.jpg")" 
                                     alt="@course.Title" 
                                     class="card-img-top featured-course-image" 
                                     style="height: 100%; object-fit: cover; width: 100%;" />
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge bg-primary">Nổi bật</span>
                                </div>
                                <div class="featured-course-overlay position-absolute top-0 start-0 w-100 h-100" style="background: rgba(13, 110, 253, 0.7);">
                                    <div class="d-flex align-items-center justify-content-center h-100">
                                        <a href="/courses/@course.Slug" class="btn btn-light">
                                            <i class="bi bi-play-fill me-2"></i>Xem ngay
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="card-body">
                                <div class="mb-2">
                                    <small class="badge bg-info text-white">@(course.Category?.Name ?? "Khác")</small>
                                </div>
                                <h5 class="card-title fw-bold">@course.Title</h5>
                                <p class="card-text text-muted small">
                                    @{
                                        var desc = course.Description ?? "Khóa học chất lượng cao";
                                        if (desc.Length > 80)
                                        {
                                            @(desc.Substring(0, 80) + "...")
                                        }
                                        else
                                        {
                                            @desc
                                        }
                                    }
                                </p>

                                <!-- Stats -->
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge bg-secondary text-white">
                                        <i class="bi bi-file-earmark-text me-1"></i>
                                        @(course.Sections?.Count ?? 0) chương
                                    </span>
                                    <span class="text-muted small">
                                        <i class="bi bi-people me-1"></i>
                                        @(course.Quantity ?? 0)
                                    </span>
                                </div>
                            </div>

                            <!-- Footer -->
                            <div class="card-footer bg-white border-top-0 pb-3">
                                <a href="/courses/@course.Slug" class="btn btn-primary w-100">
                                    Xem chi tiết <i class="bi bi-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle me-2"></i>
                Chưa có khóa học nào. Vui lòng quay lại sau!
            </div>
        }
    </div>
</section>

