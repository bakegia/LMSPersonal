@using LMSfinal.Models.EF
@model List<Classroom>
@{
    ViewData["Title"] = "Đăng Ký Lớp Học";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold">
                <i class="fa-solid fa-book-open text-primary me-2"></i>Đăng Ký Lớp Học
            </h2>
            <p class="text-muted">Danh sách các lớp học đang mở đăng ký</p>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-check-circle me-2"></i>
            @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-exclamation-circle me-2"></i>
            @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Count > 0)
    {
        <!-- Statistics -->
        <div class="row mb-4 g-3">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">Tổng Lớp Mở Đăng Ký</h6>
                        <h3 class="fw-bold text-primary">@Model.Count</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">Lớp Còn Chỗ</h6>
                        <h3 class="fw-bold text-success">@Model.Count(c => c.CurrentEnrollment < c.MaxCapacity)</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">Lớp Đã Đủ</h6>
                        <h3 class="fw-bold text-danger">@Model.Count(c => c.CurrentEnrollment >= c.MaxCapacity)</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Classrooms Table -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light border-bottom">
                <h5 class="mb-0 fw-bold">
                    <i class="fa-solid fa-list me-2"></i>Danh Sách Lớp
                </h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 5%">STT</th>
                            <th style="width: 20%">Tên Lớp</th>
                            <th style="width: 15%">Giáo Viên</th>
                            <th style="width: 15%">Môn Học</th>
                            <th style="width: 15%">Thời Khóa Biểu</th>
                            <th style="width: 12%">Sức Chứa</th>
                            <th style="width: 12%">Hạn Đăng Ký</th>
                            <th style="width: 10%">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int index = 1;
                        }
                        @foreach (var classroom in Model)
                        {
                            var isFull = classroom.CurrentEnrollment >= classroom.MaxCapacity;
                            var isDeadlinePassed = classroom.RegistrationDeadline.HasValue && DateTime.Now > classroom.RegistrationDeadline;

                            <tr>
                                <td class="fw-bold">@index</td>
                                <td>
                                    <strong>@classroom.NameClass</strong>
                                    <br>
                                    <small class="text-muted">@classroom.ClassCode</small>
                                </td>
                                <td>
                                    @if (classroom.Instructor != null)
                                    {
                                        <span class="badge bg-info">@classroom.Instructor.UserName</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Chưa có GV</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">
                                        <i class="fa-solid fa-book me-1"></i>@classroom.Course?.Title
                                    </span>
                                </td>
                                <td>
                                    @{
                                        var schedules = classroom.ClassSchedules
                                        .GroupBy(s => s.TimeSlotId)
                                        .FirstOrDefault();

                                        if (schedules != null)
                                        {
                                            var days = string.Join(", ",
                                            classroom.ClassSchedules
                                            .OrderBy(s => s.DayOfWeek)
                                            .Select(s => GetDayName(s.DayOfWeek))
                                            .Distinct());

                                            var timeSlot = schedules.First().TimeSlot;
                                            <small class="text-muted">
                                                @days<br>
                                                <strong>@timeSlot.StartTime:HH\:mm - @timeSlot.EndTime:HH\:mm</strong>
                                            </small>
                                        }
                                    }
                                </td>
                                <td>
                                    @{
                                        var capacityPercent = (classroom.CurrentEnrollment * 100) / classroom.MaxCapacity;
                                        var capacityColor = isFull ? "danger" : (capacityPercent > 80 ? "warning" : "success");
                                    }
                                    <div class="d-flex align-items-center gap-2">
                                        <small class="fw-bold">@classroom.CurrentEnrollment/@classroom.MaxCapacity</small>
                                        <div class="progress flex-grow-1" style="height: 20px;">
                                            <div class="progress-bar bg-@capacityColor" role="progressbar"
                                                 style="width: @capacityPercent%"
                                                 aria-valuenow="@classroom.CurrentEnrollment"
                                                 aria-valuemin="0"
                                                 aria-valuemax="@classroom.MaxCapacity">
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (classroom.RegistrationDeadline.HasValue)
                                    {
                                        <small class="@(isDeadlinePassed ? "text-danger fw-bold" : "text-muted")">
                                            @classroom.RegistrationDeadline.Value.ToString("dd/MM/yyyy")
                                        </small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">—</small>
                                    }
                                </td>
                                <td>
                                    @if (User.IsInRole("Student"))
                                    {
                                        var userEnrolledClassroomIds = ViewBag.UserEnrolledClassroomIds as List<int> ?? new List<int>();
                                        var userEnrolledCourseIds = ViewBag.UserEnrolledCourseIds as List<int> ?? new List<int>();

                                        var isEnrolledInThisClass = userEnrolledClassroomIds.Contains(classroom.Id);
                                        var isEnrolledInThisCourse = userEnrolledCourseIds.Contains(classroom.CourseId);

                                        if (isEnrolledInThisClass)
                                        {
                                            <form asp-action="StudentUnregister" asp-route-classroomId="@classroom.Id" method="post" 
                                                  onsubmit="return confirm('Bạn có chắc chắn muốn hủy đăng ký lớp này?');" style="display: inline;">
                                                <button type="submit" class="btn btn-sm btn-danger" title="Hủy đăng ký">
                                                    <i class="fa-solid fa-trash-can me-1"></i>Hủy Đăng Ký
                                                </button>
                                            </form>
                                        }
                                        else if (isEnrolledInThisCourse)
                                        {
                                            <button class="btn btn-sm btn-secondary" disabled title="Bạn đã đăng ký một lớp khác của môn này">
                                                <i class="fa-solid fa-triangle-exclamation me-1"></i>Đã Đăng Ký Môn Này
                                            </button>
                                        }
                                        else if (!isFull && !isDeadlinePassed)
                                        {
                                            <form asp-action="StudentRegister" asp-route-classroomId="@classroom.Id" method="post" style="display: inline;">
                                                <button type="submit" class="btn btn-sm btn-primary" title="Đăng ký lớp này">
                                                    <i class="fa-solid fa-plus me-1"></i>Đăng Ký
                                                </button>
                                            </form>
                                        }
                                        else if (isFull)
                                        {
                                            <button class="btn btn-sm btn-secondary" disabled title="Lớp đã đủ">
                                                <i class="fa-solid fa-circle-xmark me-1"></i>Đủ Chỗ
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-secondary" disabled title="Hạn đã hết">
                                                <i class="fa-solid fa-clock me-1"></i>Hạn Hết
                                            </button>
                                        }
                                    }
                                </td>
                            </tr>
                            index++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <!-- No Classrooms -->
        <div class="alert alert-info text-center py-5" role="alert">
            <i class="fa-solid fa-inbox fa-3x mb-3 text-info d-block"></i>
            <h5>Không có lớp học nào mở đăng ký</h5>
            <p class="text-muted">Vui lòng quay lại sau hoặc liên hệ quản trị viên</p>
        </div>
    }

    <!-- Back Button -->
    <div class="mt-4">
        @if (User.IsInRole("Student"))
        {
            <a asp-area="Student" asp-controller="HomeStudent" asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i>Quay Lại Dashboard
            </a>
        }
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }

    .progress {
        background-color: #e9ecef;
    }

    .badge {
        font-weight: 500;
    }

    .btn-sm {
        padding: 0.5rem 0.75rem;
    }
</style>

@functions {
    private string GetDayName(DayOfWeek day)
    {
        return day switch
        {
            DayOfWeek.Monday => "Thứ 2",
            DayOfWeek.Tuesday => "Thứ 3",
            DayOfWeek.Wednesday => "Thứ 4",
            DayOfWeek.Thursday => "Thứ 5",
            DayOfWeek.Friday => "Thứ 6",
            DayOfWeek.Saturday => "Thứ 7",
            DayOfWeek.Sunday => "CN",
            _ => day.ToString()
        };
    }
}


