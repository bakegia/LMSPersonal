@{
    ViewData["Title"] = "Privacy Policy";
}
<div class="row">
    <div class="col-md-6">
        [text* your-name placeholder "Họ và tên *"]
    </div>

    <div class="col-md-6">
        [tel* your-phone placeholder "Số điện thoại *"]
    </div>

    <div class="col-md-6">
        [email* your-email placeholder "Email *"]
    </div>

    <div class="col-md-6">
        [text your-subject placeholder "Tên doanh nghiệp"]
    </div>

    <div class="col-md-12">
        [textarea your-message placeholder "Nhu cầu của anh/chị"]
    </div>

    <div class="col-md-12 privacy-box">
        [acceptance privacy-policy]
        Tôi đồng ý với
        <a href="https://yourdomain.com/privacy-policy" target="_blank">
            Chính sách quyền riêng tư
        </a>
        [/acceptance]
    </div>

    <div class="col-md-12">
        [submit "Gửi tin nhắn"]
    </div>
</div>