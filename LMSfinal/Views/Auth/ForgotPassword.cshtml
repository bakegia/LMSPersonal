@model string 
@{
    ViewData["Title"] = "Quên mật khẩu";

}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Khôi phục mật khẩu</h1>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid d-flex justify-content-center">
        <div class="col-md-5">

            <div class="card card-outline card-info shadow-sm mt-5">
                <div class="card-header text-center">
                    <h3 class="card-title w-100">
                        <i class="fas fa- envelope mr-2"></i> Nhập Email của bạn
                    </h3>
                </div>

                <div class="card-body">
                    <p class="login-box-msg">Chúng tôi sẽ gửi một mã OTP gồm 6 chữ số đến email của bạn để xác thực.</p>

                    <form asp-controller="Auth" asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="form-group">
                            <label>Địa chỉ Email</label>
                            <div class="input-group">
                                <input type="email" name="email" class="form-control" placeholder="example@gmail.com" required>
                                <div class="input-group-append">
                                    <div class="input-group-text">
                                        <span class="fas fa-envelope"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <button type="submit" class="btn btn-info btn-block">
                                    Gửi mã xác nhận
                                </button>
                            </div>
                        </div>
                    </form>

                    <p class="mt-3 mb-1 text-center">
                        <a asp-action="Login" class="text-info">Quay lại trang đăng nhập</a>
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}