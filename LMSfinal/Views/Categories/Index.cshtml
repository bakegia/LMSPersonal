@using LMSfinal.Models.EF
@model List<Category>
@{
    ViewData["Title"] = "Danh mục khóa học - LMS Academy";
    ViewData["MetaDescription"] = "Khám phá các danh mục khóa học được sắp xếp theo lĩnh vực. Tìm khóa học phù hợp với bạn.";
    ViewData["MetaKeywords"] = "danh mục khóa học, lĩnh vực học tập, phân loại khóa học";
    ViewData["MetaImage"] = "/images/og-categories.jpg";
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="bg-light py-3 mb-4">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item active">Danh mục</li>
        </ol>
    </div>
</nav>

<!-- Page Header -->
<section class="page-header py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold text-primary mb-3">
                    <i class="bi bi-collection me-2"></i>Danh mục khóa học
                </h1>
                <p class="lead text-muted">
                    Khám phá hàng trăm khóa học được phân loại theo lĩnh vực. Chọn danh mục yêu thích của bạn để bắt đầu học tập.
                </p>
            </div>
            <div class="col-lg-4 text-end">
                <i class="bi bi-folder2-open" style="font-size: 5rem; color: var(--color-secondary); opacity: 0.3;"></i>
            </div>
        </div>
    </div>
</section>

<!-- Categories Grid -->
<section class="categories-list py-5">
    <div class="container">
        @if (Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var category in Model.OrderBy(c => c.Name))
                {
                    <div class="col-lg-3 col-md-6 col-sm-12">
                        <a href="/categories/@category.Slug" class="text-decoration-none">
                            <div class="category-item card h-100 border-0 shadow-sm">
                                <!-- Icon Background -->
                                <div class="category-item-bg" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%); height: 120px; display: flex; align-items: center; justify-content: center;">
                                    <i class="bi bi-book-fill" style="font-size: 3rem; color: var(--color-light);"></i>
                                </div>

                                <!-- Card Body -->
                                <div class="card-body text-center">
                                    <h5 class="card-title fw-bold text-primary">@category.Name</h5>
                                    
                                    <p class="card-text text-muted small">
                                        @(string.IsNullOrWhiteSpace(category.Description) ? 
                                            "Khóa học chuyên ngành" : 
                                            category.Description.Length > 60 ? 
                                            category.Description.Substring(0, 60) + "..." : 
                                            category.Description)
                                    </p>

                                    <div class="d-flex justify-content-center align-items-center gap-2 mb-3">
                                        <span class="badge bg-light text-primary">
                                            <i class="bi bi-book me-1"></i>
                                            @(category.Courses?.Count ?? 0) khóa học
                                        </span>
                                    </div>
                                </div>

                                <!-- Card Footer -->
                                <div class="card-footer bg-light border-top">
                                    <span class="text-primary fw-bold d-flex align-items-center justify-content-center">
                                        Khám phá <i class="bi bi-arrow-right ms-2"></i>
                                    </span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="empty-state text-center py-5">
                <div class="mb-4">
                    <i class="bi bi-inbox" style="font-size: 4rem; color: var(--color-gray-300);"></i>
                </div>
                <h3 class="fw-bold text-primary mb-2">Chưa có danh mục nào</h3>
                <p class="text-muted mb-4">Chúng tôi hiện đang cập nhật các danh mục khóa học. Vui lòng quay lại sau!</p>
                <a href="/" class="btn btn-primary">
                    <i class="bi bi-house me-2"></i>Quay về trang chủ
                </a>
            </div>
        }
    </div>
</section>

<!-- Statistics Section -->
@if (Model != null && Model.Any())
{
    <section class="stats-section py-5 bg-light">
        <div class="container">
            <div class="row text-center g-4">
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3 class="display-6 fw-bold text-primary">@Model.Count</h3>
                        <p class="text-muted">Danh mục</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3 class="display-6 fw-bold text-secondary">@(Model.Sum(c => c.Courses?.Count ?? 0))</h3>
                        <p class="text-muted">Khóa học</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3 class="display-6 fw-bold text-success">1000+</h3>
                        <p class="text-muted">Học viên</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3 class="display-6 fw-bold text-warning">4.8/5</h3>
                        <p class="text-muted">Đánh giá</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- CTA Section -->
@await Html.PartialAsync("_CtaSection")

