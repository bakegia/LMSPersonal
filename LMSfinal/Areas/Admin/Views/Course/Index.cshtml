    //     fetch(categoryApi)
    //         .then(r => {
    //             if (!r.ok) throw new Error(`HTTP error! status: ${r.status}`);
    //             return r.json();
    //         })
    //         .then(response => {
    //             const data = response.items || response;

    //             let html = '<option value="">-- All Categories --</option>';
    //             data.forEach(c => {
    //                 html += `<option value="${c.categoryId}">${c.name}</option>`;
    //             });

    //             document.getElementById('filterByCategory').innerHTML = html;
    //             document.getElementById('categoryId').innerHTML = html;
    //         })
    //         .catch(error => {
    //             console.error('Error loading categories:', error);
    //         });
    // }

    // =========================
    // OPEN CREATE
    // =========================
    function openCreate() {
        isEdit = false;
        document.getElementById('modalTitle').innerText = 'Add New Course';
        clearForm();
        new bootstrap.Modal('#courseModal').show();
    }

    // =========================
    // OPEN EDIT
    // =========================
    function openEdit(id) {
        isEdit = true;

        fetch(`${api}/${id}`)
            .then(r => {
                if (!r.ok) throw new Error(`HTTP error! status: ${r.status}`);
                return r.json();
            })
            .then(c => {
                document.getElementById('modalTitle').innerText = 'Edit Course';
                document.getElementById('courseId').value = c.id;
                document.getElementById('courseCode').value = c.courseCode ?? '';
                document.getElementById('title').value = c.title ?? '';
                document.getElementById('slug').value = c.slug ?? '';
                document.getElementById('description').value = c.description ?? '';
                document.getElementById('categoryId').value = c.categoryId ?? '';

                if (c.imageUrl) {
                    let preview = document.getElementById('previewImage');
                    preview.src = c.imageUrl;
                    preview.style.display = 'block';
                }

                new bootstrap.Modal('#courseModal').show();
            })
            .catch(error => {
                console.error('Error loading course:', error);
                alert('Error loading course: ' + error.message);
            });
    }

    // =========================
    // CLEAR FORM
    // =========================
    function clearForm() {
        document.getElementById('courseId').value = '';
        document.getElementById('courseCode').value = '';
        document.getElementById('title').value = '';
        document.getElementById('slug').value = '';
        document.getElementById('description').value = '';
        document.getElementById('categoryId').value = '';
        document.getElementById('imageUpload').value = '';
        document.getElementById('previewImage').style.display = 'none';
    }

    // =========================
    // SAVE COURSE
    // =========================
    function saveCourse() {
        const id = document.getElementById('courseId').value;
        const courseCode = document.getElementById('courseCode').value.trim();
        const title = document.getElementById('title').value.trim();

        if (!courseCode) {
            alert('Course Code is required');
            return;
        }
        if (!title) {
            alert('Title is required');
            return;
        }

        let formData = new FormData();
        formData.append('CourseCode', courseCode);
        formData.append('Title', title);
        formData.append('Slug', document.getElementById('slug').value);
        formData.append('Description', document.getElementById('description').value);
        formData.append('CategoryId', document.getElementById('categoryId').value);

        const file = document.getElementById('imageUpload').files[0];
        if (file) {
            formData.append('ImageUpload', file);
        }

        const method = isEdit ? 'PUT' : 'POST';
        const url = isEdit ? `${api}/${id}` : api;

        fetch(url, {
            method: method,
            body: formData
        })
        .then(response => {
            if (response.ok) {
                bootstrap.Modal.getInstance(document.getElementById('courseModal')).hide();
                currentPage = 1;
                loadData();
                alert(isEdit ? 'Course updated successfully!' : 'Course created successfully!');
            } else {
                alert('Save failed');
            }
        })
        .catch(error => {
            console.error('Save error:', error);
            alert('Error: ' + error.message);
        });
    }

    // =========================
    // DELETE COURSE
    // =========================
    function removeCourse(id) {
        if (!confirm('Are you sure you want to delete this course?'))
            return;

        fetch(`${api}/${id}`, {
            method: 'DELETE'
        })
        .then(r => {
            if (r.ok) {
                currentPage = 1;
                loadData();
                alert('Course deleted successfully!');
            } else {
                alert('Failed to delete course');
            }
        })
        .catch(error => {
            console.error('Delete error:', error);
            alert('Error: ' + error.message);
        });
    }

    // =========================
    // INIT
    // =========================
    loadCategories();
    loadData();
</script>