@{
    ViewData["Title"] = "Course Management";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h2>Course Management</h2>

<button class="btn btn-success mb-3" onclick="openCreate()">+ Add Course</button>

<!-- Filter Section -->
<div class="card mb-3">
    <div class="card-body">
        <div class="row">
            <div class="col-md-2">
                <label>Filter by ID</label>
                <input type="number" id="filterById" class="form-control" placeholder="Enter ID..." min="1" />
            </div>
            <div class="col-md-4">
                <label>Search</label>
                <input type="text" id="searchInput" class="form-control" placeholder="Search by title, code, or slug..." />
            </div>
            <div class="col-md-3">
                <label>Category</label>
                <select id="filterByCategory" class="form-select">
                    <option value="">-- All Categories --</option>
                </select>
            </div>
            <div class="col-md-3">
                <label>Sort By</label>
                <select id="sortBy" class="form-select">
                    <option value="title">Title (A-Z)</option>
                    <option value="title_desc">Title (Z-A)</option>
                    <option value="id">ID (Low to High)</option>
                    <option value="id_desc">ID (High to Low)</option>
                    <option value="code">Code (A-Z)</option>
                    <option value="code_desc">Code (Z-A)</option>
                </select>
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-md-3">
                <label>Items Per Page</label>
                <select id="pageSize" class="form-select">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
            <div class="col-md-9 d-flex align-items-end">
                <button class="btn btn-primary" onclick="resetFilter()">Reset Filter</button>
            </div>
        </div>
    </div>
</div>

<table class="table table-bordered table-hover" id="tblCourse">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Code</th>
            <th>Title</th>
            <th>Slug</th>
            <th>Category</th>
            <th>Image</th>
            <th width="180">Action</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<!-- Pagination -->
<nav aria-label="Page navigation">
    <ul class="pagination" id="paginationContainer"></ul>
</nav>

<!-- MODAL -->
<div class="modal fade" id="courseModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="modalTitle"></h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="courseId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Course Code</label>
                        <input id="courseCode" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Title</label>
                        <input id="title" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label>Slug</label>
                    <input id="slug" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Description</label>
                    <textarea id="description" class="form-control" rows="4"></textarea>
                </div>

                <div class="mb-3">
                    <label>Category</label>
                    <select id="categoryId" class="form-select"></select>
                </div>

                <div class="mb-3">
                    <label>Image</label>
                    <input type="file" id="imageUpload" class="form-control" />
                </div>

                <div class="mb-3">
                    <img id="previewImage" src="" width="120" style="display:none; border-radius:8px; border:1px solid #ccc;" />
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" onclick="saveCourse()">Save</button>
            </div>
        </div>
    </div>
</div>

<script>
    const api = "/api/course";
    const categoryApi = "/api/categories";

    let isEdit = false;
    let currentPage = 1;

    // Auto-generate slug from title
    document.getElementById('title').addEventListener('keyup', function () {
        let slug = this.value
            .toLowerCase()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .replace(/đ/g, 'd')
            .replace(/\s+/g, '-')
            .replace(/[^\w\-]+/g, '');

        document.getElementById('slug').value = slug;
    });

    // Event listeners for filter changes
    document.getElementById('filterById').addEventListener('keyup', debounce(() => {
        currentPage = 1;
        loadData();
    }, 300));

    document.getElementById('searchInput').addEventListener('keyup', debounce(() => {
        currentPage = 1;
        loadData();
    }, 300));

    document.getElementById('filterByCategory').addEventListener('change', () => {
        currentPage = 1;
        loadData();
    });

    document.getElementById('sortBy').addEventListener('change', () => {
        currentPage = 1;
        loadData();
    });

    document.getElementById('pageSize').addEventListener('change', () => {
        currentPage = 1;
        loadData();
    });

    function debounce(func, delay) {
        let timeoutId;
        return function (...args) {
            clearTimeout(timeoutId);
            timeoutId = setTimeout(() => func.apply(this, args), delay);
        };
    }

    // =========================
    // LOAD COURSES WITH FILTER
    // =========================
    function loadData() {
        const filterId = document.getElementById('filterById').value;
        const search = document.getElementById('searchInput').value;
        const categoryId = document.getElementById('filterByCategory').value;
        const sortBy = document.getElementById('sortBy').value;
        const pageSize = document.getElementById('pageSize').value;

        const params = new URLSearchParams({
            pageNumber: currentPage,
            pageSize: pageSize,
            search: search,
            sortBy: sortBy
        });

        if (categoryId && categoryId.trim() !== '') {
            params.append('categoryId', categoryId);
        }

        const fullUrl = `${api}?${params}`;
        console.log('Fetching URL:', fullUrl);

        fetch(fullUrl)
            .then(r => {
                console.log('Response Status:', r.status);
                if (!r.ok) {
                    throw new Error(`HTTP error! status: ${r.status}`);
                }
                return r.json();
            })
            .then(response => {
                console.log('Response Data:', response);

                const data = response.items || response;

                if (!data || data.length === 0) {
                    document.querySelector('#tblCourse tbody').innerHTML =
                        '<tr><td colspan="7" class="text-center text-muted">No courses found</td></tr>';
                    document.getElementById('paginationContainer').innerHTML = '';
                    return;
                }

                let html = '';
                data.forEach(c => {
                    html += `
                        <tr>
                            <td><strong>${c.id}</strong></td>
                            <td><span class="badge bg-info">${c.courseCode ?? ''}</span></td>
                            <td>${c.title ?? ''}</td>
                            <td><code>${c.slug ?? ''}</code></td>
                            <td>${c.category ? c.category.name : ''}</td>
                            <td>
                                ${c.imageUrl ? `<img src="${c.imageUrl}" width="70" style="border-radius:4px;"/>` : ''}
                            </td>
                            <td>
                                <button class="btn btn-warning btn-sm" title="Edit" onclick="openEdit(${c.id})">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                <button class="btn btn-danger btn-sm" title="Delete" onclick="removeCourse(${c.id})">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    `;
                });

                document.querySelector('#tblCourse tbody').innerHTML = html;

                if (response.totalPages !== undefined) {
                    renderPagination(response);
                }
            })
            .catch(error => {
                console.error('Error loading data:', error);
                document.querySelector('#tblCourse tbody').innerHTML =
                    `<tr><td colspan="7" class="text-center text-danger"><strong>Error:</strong> ${error.message}</td></tr>`;
            });
    }
    
    function renderPagination(response) {
        const paginationContainer = document.getElementById('paginationContainer');
        paginationContainer.innerHTML = '';

        // Previous button
        const prevLi = document.createElement('li');
        prevLi.className = `page-item ${!response.hasPreviousPage ? 'disabled' : ''}`;
        prevLi.innerHTML = `<a class="page-link" href="#" onclick="goToPage(${response.pageNumber - 1}); return false;">« Previous</a>`;
        paginationContainer.appendChild(prevLi);

        // Page numbers
        const maxVisiblePages = 5;
        const startPage = Math.max(1, response.pageNumber - Math.floor(maxVisiblePages / 2));
        const endPage = Math.min(response.totalPages, startPage + maxVisiblePages - 1);

        if (startPage > 1) {
            const firstLi = document.createElement('li');
            firstLi.className = 'page-item';
            firstLi.innerHTML = `<a class="page-link" href="#" onclick="goToPage(1); return false;">1</a>`;
            paginationContainer.appendChild(firstLi);

            if (startPage > 2) {
                const dotsLi = document.createElement('li');
                dotsLi.className = 'page-item disabled';
                dotsLi.innerHTML = `<span class="page-link">...</span>`;
                paginationContainer.appendChild(dotsLi);
            }
        }

        for (let i = startPage; i <= endPage; i++) {
            const li = document.createElement('li');
            li.className = `page-item ${i === response.pageNumber ? 'active' : ''}`;
            li.innerHTML = `<a class="page-link" href="#" onclick="goToPage(${i}); return false;">${i}</a>`;
            paginationContainer.appendChild(li);
        }

        if (endPage < response.totalPages) {
            if (endPage < response.totalPages - 1) {
                const dotsLi = document.createElement('li');
                dotsLi.className = 'page-item disabled';
                dotsLi.innerHTML = `<span class="page-link">...</span>`;
                paginationContainer.appendChild(dotsLi);
            }

            const lastLi = document.createElement('li');
            lastLi.className = 'page-item';
            lastLi.innerHTML = `<a class="page-link" href="#" onclick="goToPage(${response.totalPages}); return false;">${response.totalPages}</a>`;
            paginationContainer.appendChild(lastLi);
        }

        // Next button
        const nextLi = document.createElement('li');
        nextLi.className = `page-item ${!response.hasNextPage ? 'disabled' : ''}`;
        nextLi.innerHTML = `<a class="page-link" href="#" onclick="goToPage(${response.pageNumber + 1}); return false;">Next »</a>`;
        paginationContainer.appendChild(nextLi);
    }

    function goToPage(page) {
        if (page < 1) return;
        currentPage = page;
        loadData();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function resetFilter() {
        document.getElementById('filterById').value = '';
        document.getElementById('searchInput').value = '';
        document.getElementById('filterByCategory').value = '';
        document.getElementById('sortBy').value = 'title';
        document.getElementById('pageSize').value = '10';
        currentPage = 1;
        loadData();
    }

    // =========================
    // LOAD CATEGORIES
    // =========================
        function loadCategories() {
        fetch(`${categoryApi}?pageNumber=1&pageSize=999`)
            .then(r => {
                if (!r.ok)
                    throw new Error(`HTTP error! status: ${r.status}`);

                return r.json();
            })
            .then(response => {

                const data = response.items;

                let filterHtml =
                    '<option value="">-- All Categories --</option>';

                let modalHtml =
                    '<option value="">-- Select Category --</option>';

                data.forEach(c => {
                    filterHtml += `
                        <option value="${c.categoryId}">
                            ${c.name}
                        </option>
                    `;

                    modalHtml += `
                        <option value="${c.categoryId}">
                            ${c.name}
                        </option>
                    `;
                });

                document.getElementById("filterByCategory").innerHTML = filterHtml;
                document.getElementById("categoryId").innerHTML = modalHtml;
            });
    }
