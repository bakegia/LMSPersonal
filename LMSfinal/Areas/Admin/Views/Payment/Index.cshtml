@using LMSfinal.Models.EF
@using LMSfinal.Models.Enums
@model List<ClassroomPayment>

@{
    ViewData["Title"] = "Quản lý thanh toán";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="fa-solid fa-money-check-dollar"></i> Quản lý thanh toán</h3>
        <form asp-action="LockOverdue" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">
                <i class="fa-solid fa-lock"></i> Khóa học sinh quá hạn
            </button>
        </form>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">@TempData["success"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">Chưa có hóa đơn.</div>
    }
    else
    {
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Học sinh</th>
                    <th>Lớp</th>
                    <th>Môn</th>
                    <th>Số tiền</th>
                    <th>Hạn</th>
                    <th>Trạng thái</th>
                    <th>Thanh toán</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var statusClass = item.Status switch
                    {
                        PaymentStatus.Paid => "bg-success",
                        PaymentStatus.Overdue => "bg-danger",
                        _ => "bg-warning text-dark"
                    };

                    var statusLabel = item.Status switch
                    {
                        PaymentStatus.Paid => "Đã thanh toán",
                        PaymentStatus.Overdue => "Quá hạn",
                        _ => "Chờ thanh toán"
                    };

                    <tr>
                        <td>@item.Student?.FullName</td>
                        <td>@item.Classroom?.NameClass</td>
                        <td>@item.Classroom?.Course?.Title</td>
                        <td>@item.Amount.ToString("N0") VNĐ</td>
                        <td>@item.DueDate.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge @statusClass">@statusLabel</span></td>
                        <td>@(item.PaidAt?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td class="d-flex gap-2">
                            @if (item.Status != PaymentStatus.Paid)
                            {
                                <form asp-action="MarkPaid" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn btn-success btn-sm">
                                        <i class="fa-solid fa-check"></i> Đã thanh toán
                                    </button>
                                </form>
                            }
                            <form asp-action="Unlock" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button class="btn btn-outline-secondary btn-sm">
                                    <i class="fa-solid fa-unlock"></i> Mở khóa
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>