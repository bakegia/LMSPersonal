@{
    ViewData["Title"] = "Loại Khóa Học";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h2>Category Management</h2>

<button class="btn btn-success mb-3" onclick="openCreate()">+ Add Category</button>

<!-- Filter Section -->
<div class="card mb-3">
    <div class="card-body">
        <div class="row">
            <div class="col-md-2">
                <label>Filter by ID</label>
                <input type="number" id="filterById" class="form-control" placeholder="Enter ID..." min="1" />
            </div>
            <div class="col-md-4">
                <label>Search</label>
                <input type="text" id="searchInput" class="form-control" placeholder="Search by name, code, or slug..." />
            </div>
            <div class="col-md-3">
                <label>Sort By</label>
                <select id="sortBy" class="form-select">
                    <option value="id">ID (Low to High)</option>
                    <option value="id_desc">ID (High to Low)</option>
                    <option value="name">Name (A-Z)</option>
                    <option value="name_desc">Name (Z-A)</option>
                    <option value="code">Code (A-Z)</option>
                    <option value="code_desc">Code (Z-A)</option>
                </select>
            </div>
            <div class="col-md-3">
                <label>Items Per Page</label>
                <select id="pageSize" class="form-select">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
        </div>
        <button class="btn btn-primary mt-3" onclick="resetFilter()">Reset</button>
    </div>
</div>

<table class="table table-bordered table-hover" id="tblCategory">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Code</th>
            <th>Slug</th>
            <th>Description</th>
            <th width="150">Action</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<!-- Pagination -->
<nav aria-label="Page navigation">
    <ul class="pagination" id="paginationContainer"></ul>
</nav>

<!-- MODAL -->
<div class="modal fade" id="categoryModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 id="modalTitle"></h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="categoryId" />

                <div class="mb-3">
                    <label>Name</label>
                    <input id="name" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Category Code</label>
                    <input id="categoryCode" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Slug</label>
                    <input id="slug" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Description</label>
                    <textarea id="desc" class="form-control" rows="3"></textarea>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" onclick="save()">Save</button>
            </div>

        </div>
    </div>
</div>

<script>
    const api = '/api/categories';
    let isEdit = false;
    let currentPage = 1;

    console.log('API Endpoint:', api);

    // Auto-generate slug from name
    document.getElementById('name').addEventListener('keyup', function () {
        let slug = this.value
            .toLowerCase()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .replace(/đ/g, 'd')
            .replace(/\s+/g, '-')
            .replace(/[^\w\-]+/g, '');

        document.getElementById('slug').value = slug;
    });

    // Event listeners for filter changes
    document.getElementById('filterById').addEventListener('keyup', debounce(() => {
        currentPage = 1;
        loadData();
    }, 300));

    document.getElementById('searchInput').addEventListener('keyup', debounce(() => {
        currentPage = 1;
        loadData();
    }, 300));

    document.getElementById('sortBy').addEventListener('change', () => {
        currentPage = 1;
        loadData();
    });

    document.getElementById('pageSize').addEventListener('change', () => {
        currentPage = 1;
        loadData();
    });

    function debounce(func, delay) {
        let timeoutId;
        return function (...args) {
            clearTimeout(timeoutId);
            timeoutId = setTimeout(() => func.apply(this, args), delay);
        };
    }

    function loadData() {
        const filterById = document.getElementById('filterById').value;
        const search = document.getElementById('searchInput').value;
        const sortBy = document.getElementById('sortBy').value;
        const pageSize = document.getElementById('pageSize').value;

        const params = new URLSearchParams({
            pageNumber: currentPage,
            pageSize: pageSize,
            search: search,
            sortBy: sortBy
        });

        // Add categoryId filter only if it has a value
        if (filterById && filterById.trim() !== '') {
            params.append('categoryId', filterById);
        }

        const fullUrl = `${api}?${params}`;
        console.log('Fetching URL:', fullUrl);

        fetch(fullUrl)
            .then(r => {
                console.log('Response Status:', r.status);
                if (!r.ok) {
                    throw new Error(`HTTP error! status: ${r.status}`);
                }
                return r.json();
            })
            .then(response => {
                console.log('Response Data:', response);

                const data = response.items || response;
                console.log('Items Array:', data);

                if (!data || data.length === 0) {
                    console.warn('No data received');
                    document.querySelector('#tblCategory tbody').innerHTML =
                        '<tr><td colspan="6" class="text-center text-muted">No categories found</td></tr>';
                    document.getElementById('paginationContainer').innerHTML = '';
                    return;
                }

                let html = '';

                data.forEach(c => {
                    const description = (c.description || '').substring(0, 50) + (c.description && c.description.length > 50 ? '...' : '');

                    html += `
                        <tr>
                            <td><strong>${c.categoryId}</strong></td>
                            <td>${c.name ?? ''}</td>
                            <td><span class="badge bg-info">${c.categoryCode ?? ''}</span></td>
                            <td><code>${c.slug ?? ''}</code></td>
                            <td>${description}</td>
                            <td>
                                <button class="btn btn-warning btn-sm" title="Edit"
                                    onclick="openEdit(${c.categoryId})">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>

                                <button class="btn btn-danger btn-sm" title="Delete"
                                    onclick="remove(${c.categoryId})">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    `;
                });

                document.querySelector('#tblCategory tbody').innerHTML = html;
                console.log('Table updated with', data.length, 'rows');

                if (response.totalPages !== undefined) {
                    renderPagination(response);
                }
            })
            .catch(error => {
                console.error('Error loading data:', error);
                document.querySelector('#tblCategory tbody').innerHTML =
                    `<tr><td colspan="6" class="text-center text-danger"><strong>Error:</strong> ${error.message}</td></tr>`;
            });
    }

    function renderPagination(response) {
        console.log('Rendering pagination:', response);

        const paginationContainer = document.getElementById('paginationContainer');
        paginationContainer.innerHTML = '';

        // Previous button
        const prevLi = document.createElement('li');
        prevLi.className = `page-item ${!response.hasPreviousPage ? 'disabled' : ''}`;
        prevLi.innerHTML = `<a class="page-link" href="#" onclick="goToPage(${response.pageNumber - 1}); return false;">« Previous</a>`;
        paginationContainer.appendChild(prevLi);

        // Page numbers
        const maxVisiblePages = 5;
        const startPage = Math.max(1, response.pageNumber - Math.floor(maxVisiblePages / 2));
        const endPage = Math.min(response.totalPages, startPage + maxVisiblePages - 1);

        if (startPage > 1) {
            const firstLi = document.createElement('li');
            firstLi.className = 'page-item';
            firstLi.innerHTML = `<a class="page-link" href="#" onclick="goToPage(1); return false;">1</a>`;
            paginationContainer.appendChild(firstLi);

            if (startPage > 2) {
                const dotsLi = document.createElement('li');
                dotsLi.className = 'page-item disabled';
                dotsLi.innerHTML = `<span class="page-link">...</span>`;
                paginationContainer.appendChild(dotsLi);
            }
        }

        for (let i = startPage; i <= endPage; i++) {
            const li = document.createElement('li');
            li.className = `page-item ${i === response.pageNumber ? 'active' : ''}`;
            li.innerHTML = `<a class="page-link" href="#" onclick="goToPage(${i}); return false;">${i}</a>`;
            paginationContainer.appendChild(li);
        }

        if (endPage < response.totalPages) {
            if (endPage < response.totalPages - 1) {
                const dotsLi = document.createElement('li');
                dotsLi.className = 'page-item disabled';
                dotsLi.innerHTML = `<span class="page-link">...</span>`;
                paginationContainer.appendChild(dotsLi);
            }

            const lastLi = document.createElement('li');
            lastLi.className = 'page-item';
            lastLi.innerHTML = `<a class="page-link" href="#" onclick="goToPage(${response.totalPages}); return false;">${response.totalPages}</a>`;
            paginationContainer.appendChild(lastLi);
        }

        // Next button
        const nextLi = document.createElement('li');
        nextLi.className = `page-item ${!response.hasNextPage ? 'disabled' : ''}`;
        nextLi.innerHTML = `<a class="page-link" href="#" onclick="goToPage(${response.pageNumber + 1}); return false;">Next »</a>`;
        paginationContainer.appendChild(nextLi);
    }

    function goToPage(page) {
        if (page < 1) return;
        currentPage = page;
        loadData();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function resetFilter() {
        document.getElementById('filterById').value = '';
        document.getElementById('searchInput').value = '';
        document.getElementById('sortBy').value = 'id';
        document.getElementById('pageSize').value = '10';
        currentPage = 1;
        loadData();
    }

    function openCreate() {
        isEdit = false;

        document.getElementById('modalTitle').innerText = 'Add New Category';

        document.getElementById('categoryId').value = '';
        document.getElementById('name').value = '';
        document.getElementById('categoryCode').value = '';
        document.getElementById('slug').value = '';
        document.getElementById('desc').value = '';

        new bootstrap.Modal('#categoryModal').show();
    }

    function openEdit(id) {
        isEdit = true;

        fetch(`${api}/${id}`)
            .then(r => {
                console.log('Edit response status:', r.status);
                if (!r.ok) {
                    throw new Error(`HTTP error! status: ${r.status}`);
                }
                return r.json();
            })
            .then(c => {
                console.log('Edit data:', c);

                document.getElementById('categoryId').value = c.categoryId;
                document.getElementById('name').value = c.name ?? '';
                document.getElementById('categoryCode').value = c.categoryCode ?? '';
                document.getElementById('slug').value = c.slug ?? '';
                document.getElementById('desc').value = c.description ?? '';

                document.getElementById('modalTitle').innerText = 'Edit Category';

                new bootstrap.Modal('#categoryModal').show();
            })
            .catch(error => {
                console.error('Error loading category:', error);
                alert('Error loading category: ' + error.message);
            });
    }

    function save() {
        const idValue = document.getElementById('categoryId').value;
        const name = document.getElementById('name').value.trim();
        const categoryCode = document.getElementById('categoryCode').value.trim();
        const slug = document.getElementById('slug').value.trim();
        const description = document.getElementById('desc').value.trim();

        // Validation
        if (!name) {
            alert('Name is required');
            return;
        }
        if (!categoryCode) {
            alert('Category Code is required');
            return;
        }
        if (!slug) {
            alert('Slug is required');
            return;
        }

        const obj = {
            CategoryId: idValue ? parseInt(idValue) : 0,
            Name: name,
            CategoryCode: categoryCode,
            Slug: slug,
            Description: description
        };

        console.log('Saving object:', obj);

        const method = isEdit ? 'PUT' : 'POST';
        const url = isEdit
            ? `${api}/${obj.CategoryId}`
            : api;

        console.log('Request URL:', url, 'Method:', method);

        fetch(url, {
            method: method,
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(obj)
        })
        .then(response => {
            console.log('Save response status:', response.status);

            if (response.ok) {
                const modalElement = document.getElementById('categoryModal');
                bootstrap.Modal.getInstance(modalElement).hide();
                currentPage = 1;
                loadData();
                alert(isEdit ? 'Category updated successfully!' : 'Category created successfully!');
            } else {
                return response.json().then(err => {
                    console.error('Save error:', err);
                    alert('Error: ' + JSON.stringify(err));
                });
            }
        })
        .catch(error => {
            console.error('Save fetch error:', error);
            alert('Error: ' + error.message);
        });
    }

    function remove(id) {
        if (!confirm('Are you sure you want to delete this category?'))
            return;

        console.log('Deleting category:', id);

        fetch(`${api}/${id}`, {
            method: 'DELETE'
        })
        .then(r => {
            console.log('Delete response status:', r.status);
            if (r.ok) {
                currentPage = 1;
                loadData();
                alert('Category deleted successfully!');
            } else {
                alert('Failed to delete category');
            }
        })
        .catch(error => {
            console.error('Delete error:', error);
            alert('Error: ' + error.message);
        });
    }

    // Initial load
    console.log('Page loaded, calling loadData()');
    loadData();
</script>