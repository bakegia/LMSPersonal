@using LMSfinal.Models.ViewModels
@model ClassroomVM
@{
    ViewData["Title"] = "Chỉnh Sửa Lớp Học";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold">
                <i class="fa-solid fa-pen text-warning me-2"></i>Chỉnh Sửa Lớp Học
            </h2>
            <p class="text-muted">Cập nhật thông tin lớp học</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                <input type="hidden" asp-for="Id">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <strong>Lỗi:</strong>
                        <ul class="mb-0">
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <!-- SECTION 1: THÔNG TIN CƠ BẢN -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-light border-bottom">
                        <h5 class="mb-0 fw-bold">
                            <i class="fa-solid fa-circle-info me-2 text-primary"></i>Thông Tin Cơ Bản
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="ClassCode" class="form-label fw-bold">Mã Lớp <span class="text-danger">*</span></label>
                            <input asp-for="ClassCode" class="form-control" required>
                            <span asp-validation-for="ClassCode" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NameClass" class="form-label fw-bold">Tên Lớp <span class="text-danger">*</span></label>
                            <input asp-for="NameClass" class="form-control" required>
                            <span asp-validation-for="NameClass" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô Tả <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <!-- SECTION 2: KHÓA HỌC & GIÁO VIÊN -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-light border-bottom">
                        <h5 class="mb-0 fw-bold">
                            <i class="fa-solid fa-book me-2 text-info"></i>Khóa Học & Giáo Viên
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="CourseId" class="form-label fw-bold">Môn Học <span class="text-danger">*</span></label>
                            <select asp-for="CourseId" asp-items="Model.Courses" class="form-select" required>
                                <option>-- Chọn Môn Học --</option>
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="InstructorId" class="form-label fw-bold">Giáo Viên (Tùy Chọn)</label>
                            <small class="text-muted d-block mb-2">
                                <i class="fa-solid fa-info-circle me-1"></i>
                                Để trống để giáo viên tự đăng ký dạy lớp
                            </small>
                            <select asp-for="InstructorId" asp-items="Model.Instructors" class="form-select">
                                <option value="">-- Không chọn --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- SECTION 3: THỜI KHÓA BIỂU -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-light border-bottom">
                        <h5 class="mb-0 fw-bold">
                            <i class="fa-solid fa-calendar me-2 text-warning"></i>Thời Khóa Biểu
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="TimeSlotId" class="form-label fw-bold">Ca Học <span class="text-danger">*</span></label>
                            <select asp-for="TimeSlotId" asp-items="Model.TimeSlots" class="form-select" required>
                                <option value="0">-- Chọn Ca Học --</option>
                            </select>
                            <span asp-validation-for="TimeSlotId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngày Học Trong Tuần <span class="text-danger">*</span></label>
                            <div class="row">
                                @{
                                    var days = new[]
                                    {
                                                                (DayOfWeek.Monday, "Thứ 2"),
                                                                (DayOfWeek.Tuesday, "Thứ 3"),
                                                                (DayOfWeek.Wednesday, "Thứ 4"),
                                                                (DayOfWeek.Thursday, "Thứ 5"),
                                                                (DayOfWeek.Friday, "Thứ 6"),
                                                                (DayOfWeek.Saturday, "Thứ 7"),
                                                                (DayOfWeek.Sunday, "Chủ Nhật")
                                                                };
                                }
                                @foreach (var (day, dayName) in days)
                                {
                                    var isChecked = Model.SelectedDays?.Contains(day) ?? false;
                                    <div class="col-6 col-md-3 mb-2">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input"
                                                   name="SelectedDays" value="@((int)day)"
                                                   id="day_@day" @(isChecked ? "checked" : "")>
                                            <label class="form-check-label" for="day_@day">
                                                @dayName
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECTION 4: NGÀY HỌC & ĐĂNG KÝ -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-light border-bottom">
                        <h5 class="mb-0 fw-bold">
                            <i class="fa-solid fa-clock me-2 text-success"></i>Thời Gian & Đăng Ký
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label fw-bold">Ngày Bắt Đầu <span class="text-danger">*</span></label>
                                <input asp-for="StartDate" type="date" class="form-control" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label fw-bold">Ngày Kết Thúc <span class="text-danger">*</span></label>
                                <input asp-for="EndDate" type="date" class="form-control" required>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MaxCapacity" class="form-label fw-bold">Sức Chứa (Học Sinh) <span class="text-danger">*</span></label>
                                <input asp-for="MaxCapacity" type="number" class="form-control" min="1" max="200" required>
                                <small class="text-muted">Số lượng học sinh tối đa trong lớp</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="RegistrationDeadline" class="form-label fw-bold">Hạn Đăng Ký (Tùy Chọn)</label>
                                <input asp-for="RegistrationDeadline" type="datetime-local" class="form-control">
                                <small class="text-muted">Để trống = không giới hạn</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECTION 5: CẤU HÌNH -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-light border-bottom">
                        <h5 class="mb-0 fw-bold">
                            <i class="fa-solid fa-gear me-2 text-secondary"></i>Cấu Hình
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input asp-for="IsOpenForRegistration" type="checkbox" class="form-check-input">
                            <label class="form-check-label" for="IsOpenForRegistration">
                                <strong>Mở Đăng Ký</strong>
                                <br>
                                <small class="text-muted">Cho phép học sinh & giáo viên đăng ký</small>
                            </label>
                        </div>

                        <div class="form-check form-switch">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input">
                            <label class="form-check-label" for="IsActive">
                                <strong>Hoạt Động</strong>
                                <br>
                                <small class="text-muted">Lớp học có thể được sử dụng</small>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Submit Buttons -->
                <div class="d-flex gap-2 mb-4">
                    <button type="submit" class="btn btn-warning btn-lg">
                        <i class="fa-solid fa-save me-2"></i>Cập Nhật
                    </button>
                    <a asp-action="Index" class="btn btn-secondary btn-lg">
                        <i class="fa-solid fa-x me-2"></i>Hủy
                    </a>
                </div>
            </form>
        </div>

        <!-- Side Info -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0 fw-bold">
                        <i class="fa-solid fa-circle-info me-2 text-info"></i>Thông Tin Lớp
                    </h5>
                </div>
                <div class="card-body small">
                    <p class="mb-2">
                        <strong>Mã Lớp:</strong> <code>@Model.ClassCode</code>
                    </p>
                    <p class="mb-2">
                        <strong>Trạng Thái:</strong><br>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Hoạt Động</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Vô Hiệu</span>
                        }
                    </p>
                    <p class="mb-0">
                        <strong>Đăng Ký:</strong><br>
                        @if (Model.IsOpenForRegistration)
                        {
                            <span class="badge bg-success">Mở</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Đóng</span>
                        }
                    </p>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0 fw-bold">
                        <i class="fa-solid fa-lightbulb me-2 text-warning"></i>Lưu Ý
                    </h5>
                </div>
                <div class="card-body small">
                    <p class="text-muted mb-0">
                        ⚠️ Cập nhật thông tin lớp học sẽ ảnh hưởng đến tất cả học sinh và giáo viên đang tham gia
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    code {
        background-color: #f5f5f5;
        padding: 0.2rem 0.4rem;
        border-radius: 3px;
    }

    .form-check-input:checked {
        background-color: #ffc107;
        border-color: #ffc107;
    }
</style>