@model ClassroomVM

@{
    ViewData["Title"] = "Chỉnh sửa Lớp học";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="fa-solid fa-school-flag me-2"></i>Chỉnh sửa Lớp học</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-area="Admin" asp-controller="Classroom" asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <!-- Mã lớp -->
                                <div class="form-group mb-3">
                                    <label asp-for="ClassCode" class="fw-bold mb-1">Mã lớp</label>
                                    <input asp-for="ClassCode" class="form-control" placeholder="Ví dụ: C2401L" />
                                    <span asp-validation-for="ClassCode" class="text-danger small d-block mt-1"></span>
                                </div>

                                <!-- Tên lớp -->
                                <div class="form-group mb-3">
                                    <label asp-for="NameClass" class="fw-bold mb-1">Tên lớp</label>
                                    <input asp-for="NameClass" class="form-control" />
                                    <span asp-validation-for="NameClass" class="text-danger small d-block mt-1"></span>
                                </div>

                                <!-- Mô tả -->
                                <div class="form-group mb-3">
                                    <label asp-for="Description" class="fw-bold mb-1">Mô tả ngắn</label>
                                    <input asp-for="Description" class="form-control" />
                                    <span asp-validation-for="Description" class="text-danger small d-block mt-1"></span>
                                </div>

                                <!-- Ngày bắt đầu & kết thúc -->
                                <div class="row">
                                    <div class="col-6">
                                        <div class="form-group mb-3">
                                            <label asp-for="StartDate" class="fw-bold mb-1">Ngày bắt đầu</label>
                                            <input asp-for="StartDate" type="date" class="form-control" />
                                            <span asp-validation-for="StartDate" class="text-danger small d-block mt-1"></span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="form-group mb-3">
                                            <label asp-for="EndDate" class="fw-bold mb-1">Ngày kết thúc</label>
                                            <input asp-for="EndDate" type="date" class="form-control" />
                                            <span asp-validation-for="EndDate" class="text-danger small d-block mt-1"></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Giảng viên -->
                                <div class="form-group mb-3">
                                    <label class="fw-bold mb-1">Giảng viên</label>
                                    <select asp-for="InstructorId" asp-items="Model.Instructors" class="form-select">
                                        <option value="">-- Chọn giảng viên --</option>
                                    </select>
                                    <span asp-validation-for="InstructorId" class="text-danger small d-block mt-1"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <!-- Môn học -->
                                <div class="form-group mb-3">
                                    <label class="fw-bold mb-1">Môn học (Course)</label>
                                    <select asp-for="CourseId" asp-items="Model.Courses" class="form-select">
                                        <option value="">-- Chọn môn học --</option>
                                    </select>
                                    <span asp-validation-for="CourseId" class="text-danger small d-block mt-1"></span>
                                </div>

                                <!-- Danh sách sinh viên -->
                                <div class="form-group mb-3">
                                    <label class="fw-bold mb-1">Danh sách sinh viên <small class="text-muted text-italic">(Giữ Ctrl để chọn nhiều)</small></label>
                                    <select asp-for="StudentIds" asp-items="Model.Students" class="form-control" multiple style="height: 120px;">
                                    </select>
                                    <span asp-validation-for="StudentIds" class="text-danger small d-block mt-1"></span>
                                </div>

                                <!-- Lịch học -->
                                <div class="form-group mb-3 border rounded p-3 bg-light">
                                    <label class="fw-bold mb-2 text-primary"><i class="fa-solid fa-clock me-1"></i> Lịch học</label>

                                    <select asp-for="TimeSlotId" asp-items="Model.TimeSlots" class="form-select mb-3">
                                        <option value="">-- Chọn ca học --</option>
                                    </select>

                                    <div class="d-flex flex-wrap gap-3 mb-2">
                                        <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" name="SelectedDays" value="1" /> T2</label>
                                        <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" name="SelectedDays" value="2" /> T3</label>
                                        <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" name="SelectedDays" value="3" /> T4</label>
                                        <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" name="SelectedDays" value="4" /> T5</label>
                                        <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" name="SelectedDays" value="5" /> T6</label>
                                        <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" name="SelectedDays" value="6" /> T7</label>
                                        <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" name="SelectedDays" value="0" /> CN</label>
                                    </div>

                                    <div class="btn-group w-100">
                                        <button type="button" class="btn btn-sm btn-info text-white" onclick="select246()">Chọn 2-4-6</button>
                                        <button type="button" class="btn btn-sm btn-dark text-white" onclick="select357()">Chọn 3-5-7</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Trạng thái -->
                        <div class="form-check form-switch mb-4">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" id="flexSwitchCheckChecked">
                            <label class="form-check-label" for="flexSwitchCheckChecked">Kích hoạt lớp học</label>
                        </div>

                        <!-- Action Buttons -->
                        <div class="text-end border-top pt-3">
                            <a asp-action="Index" class="btn btn-light px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary px-5"><i class="fa-solid fa-save me-1"></i> Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function clearAll() {
            document.querySelectorAll('input[name="SelectedDays"]').forEach(x => x.checked = false);
        }
        function select246() {
            clearAll();
            [1, 3, 5].forEach(v => document.querySelector(`input[name="SelectedDays"][value="${v}"]`).checked = true);
        }
        function select357() {
            clearAll();
            [2, 4, 6].forEach(v => document.querySelector(`input[name="SelectedDays"][value="${v}"]`).checked = true);
        }
    </script>
}