@model LMSfinal.Models.EF.UserProfile

@{
    ViewData["Title"] = "Chi tiết học sinh";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    .profile-card {
        border-radius: 20px;
        overflow: hidden;
        border: none;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }

    .profile-header {
        height: 140px;
        background: linear-gradient(135deg,#0d6efd,#4e73df);
    }

    .profile-avatar {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid white;
        margin-top: -70px;
        background: white;
    }

    .info-box {
        padding: 15px;
        border-radius: 12px;
        background: #f8f9fa;
        margin-bottom: 15px;
        transition: .3s;
    }

        .info-box:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,.08);
        }

    .info-title {
        font-size: 13px;
        color: #777;
    }

    .info-value {
        font-size: 16px;
        font-weight: 600;
    }

    .action-btn {
        min-width: 120px;
    }
</style>

<h2 class="mb-4">
    <i class="bi bi-person-vcard"></i>
    Student Profile
</h2>

@if (Model == null)
{
    <div class="alert alert-danger">
        Không tìm thấy dữ liệu học sinh
    </div>
}
else
{
    <div class="card profile-card">

        <div class="profile-header"></div>

        <div class="card-body">

            <div class="text-center">

                @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                {
                    <img src="@Model.ProfilePictureUrl"
                         class="profile-avatar" />
                }
                else
                {
                    <img src="/images/default-user.png"
                         class="profile-avatar" />
                }

                <h3 class="mt-3">@Model.Fullname</h3>
                <p class="text-muted">
                    Student ID: @Model.Mssv
                </p>
            </div>

            <hr />

            <div class="row">

                <div class="col-md-6">
                    <div class="info-box">
                        <div class="info-title">
                            <i class="bi bi-envelope"></i> Email
                        </div>
                        <div class="info-value">
                            @Model.Email
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-box">
                        <div class="info-title">
                            <i class="bi bi-telephone"></i> Phone
                        </div>
                        <div class="info-value">
                            @Model.PhoneNumber
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-box">
                        <div class="info-title">
                            <i class="bi bi-calendar-event"></i>
                            Date of Birth
                        </div>

                        <div class="info-value">
                            @Model.DateOfBirth.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-box">
                        <div class="info-title">
                            <i class="bi bi-gender-ambiguous"></i>
                            Gender
                        </div>

                        <div class="info-value">
                            @Model.Gender
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="info-box">
                        <div class="info-title">
                            <i class="bi bi-geo-alt"></i>
                            Address
                        </div>

                        <div class="info-value">
                            @Model.Address
                        </div>
                    </div>
                </div>

            </div>

            <div class="text-center mt-4">

                <a asp-action="UpdateProfile"
                   asp-route-userId="@Model.UserId"
                   class="btn btn-warning action-btn">

                    <i class="bi bi-pencil-square"></i>
                    Edit
                </a>

                <a asp-area="Admin"
                   asp-controller="Account"
                   asp-action="Index"
                   class="btn btn-secondary action-btn">

                    <i class="bi bi-arrow-left"></i>
                    Quay lại
                </a>

            </div>

        </div>

    </div>
}