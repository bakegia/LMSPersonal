@using LMSfinal.Models.ViewModels
@model UpdateInstructorVM
@{
    ViewData["Title"] = "Chỉnh Sửa Thông Tin Giáo Viên";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid d-flex justify-content-center">
        <div class="col-md-8">
            <div class="card card-success shadow-sm">
                <div class="card-header text-center">
                    <h3 class="card-title w-100">
                        <i class="fas fa-chalkboard-user mr-2"></i> Chỉnh Sửa Thông Tin Giáo Viên
                    </h3>
                </div>

                <div class="card-body">
                    @if (TempData["success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <form asp-area="Admin"
                          asp-controller="Account"
                          asp-action="UpdateInstructorProfile"
                          method="post"
                          enctype="multipart/form-data">

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="CreatedAt" />
                        <input type="hidden" asp-for="UpdatedAt" />

                        <!-- Avatar Upload -->
                        <div class="form-group mb-4">
                            <label><i class="fas fa-image mr-1"></i> Ảnh Đại Diện</label>
                            <div class="row">
                                <div class="col-md-3 text-center">
                                    @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                                    {
                                        <img id="previewImage" 
                                             src="@Model.ProfileImageUrl" 
                                             alt="@Model.FullName"
                                             style="max-width: 100%; border-radius: 8px; border: 2px solid #ddd; height: auto;">
                                    }
                                    else
                                    {
                                        <img id="previewImage" 
                                             src="https://via.placeholder.com/150" 
                                             alt="No Avatar"
                                             style="max-width: 100%; border-radius: 8px; border: 2px solid #ddd; height: auto;">
                                    }
                                </div>
                                <div class="col-md-9">
                                    <input type="file" 
                                           id="imageUpload" 
                                           asp-for="ImageUpload"
                                           class="form-control" 
                                           accept="image/*" />
                                    <small class="form-text text-muted">
                                        Chọn hình ảnh JPG, PNG (tối đa 5MB)
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-user mr-1"></i> Tên Đầy Đủ <span class="text-danger">*</span></label>
                                    <input asp-for="FullName" class="form-control" />
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-envelope mr-1"></i> Email <span class="text-danger">*</span></label>
                                    <input asp-for="Email" type="email" class="form-control" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-phone mr-1"></i> Số Điện Thoại <span class="text-danger">*</span></label>
                                    <input asp-for="PhoneNumber" type="tel" class="form-control" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-building mr-1"></i> Bộ Môn <span class="text-danger">*</span></label>
                                    <input asp-for="Department" class="form-control" />
                                    <span asp-validation-for="Department" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-book mr-1"></i> Môn Học Chuyên Trách <span class="text-danger">*</span></label>
                                    <input asp-for="SpecializedSubject" class="form-control" />
                                    <span asp-validation-for="SpecializedSubject" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-barcode mr-1"></i> Mã Nhân Viên</label>
                                    <input asp-for="EmployeeCode" class="form-control" readonly />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-calendar mr-1"></i> Ngày Bắt Đầu Làm Việc <span class="text-danger">*</span></label>
                                    <input asp-for="HireDate" type="date" class="form-control" />
                                    <span asp-validation-for="HireDate" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-toggle-on mr-1"></i> Trạng Thái</label>
                                    <div class="form-check form-switch mt-2">
                                        <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActive" />
                                        <label class="form-check-label" for="IsActive">
                                            @if (Model.IsActive)
                                            {
                                                <span class="badge bg-success">Hoạt động</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Bị khóa</span>
                                            }
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="fas fa-save"></i> Lưu Thay Đổi
                            </button>

                            <a href="@Url.Action("InstructorDetail", "Account", new { area = "Admin", userId = Model.UserId })" 
                               class="btn btn-secondary px-4">
                                <i class="fas fa-times"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Preview Image Before Upload
        document.getElementById('imageUpload').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    document.getElementById('previewImage').src = event.target.result;
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}