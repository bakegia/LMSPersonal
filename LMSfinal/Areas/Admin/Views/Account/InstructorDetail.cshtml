@model LMSfinal.Models.ViewModels.UpdateInstructorVM
@{
    ViewData["Title"] = "Chi Tiết Giáo Viên";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-4">
                <div class="card card-success">
                    <div class="card-body box-profile">
                        <div class="text-center">
                            @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                            {
                                <img class="profile-user-img img-fluid img-circle" 
                                     src="@Model.ProfileImageUrl" 
                                     alt="@Model.FullName"
                                     style="width: 100px; height: 100px;">
                            }
                            else
                            {
                                <img class="profile-user-img img-fluid img-circle" 
                                     src="https://via.placeholder.com/100" 
                                     alt="No Avatar"
                                     style="width: 100px; height: 100px;">
                            }
                        </div>

                        <h3 class="profile-username text-center">@Model.FullName</h3>

                        <p class="text-muted text-center">
                            <small>@Model.Department</small>
                        </p>

                        <ul class="list-group list-group-unbordered mb-3">
                            <li class="list-group-item">
                                <b>Email:</b> <a href="mailto:@Model.Email">@Model.Email</a>
                            </li>
                            <li class="list-group-item">
                                <b>Điện thoại:</b> @Model.PhoneNumber
                            </li>
                            <li class="list-group-item">
                                <b>Môn học:</b> @Model.SpecializedSubject
                            </li>
                            <li class="list-group-item">
                                <b>Mã nhân viên:</b> @Model.EmployeeCode
                            </li>
                            <li class="list-group-item">
                                <b>Ngày bắt đầu:</b> @Model.HireDate.ToString("dd/MM/yyyy")
                            </li>
                            <li class="list-group-item">
                                <b>Trạng thái:</b> 
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Bị khóa</span>
                                }
                            </li>
                        </ul>

                        <div class="d-flex gap-2">
                            <a href="@Url.Action("UpdateInstructorProfile", "Account", new { area = "Admin", userId = Model.UserId })" 
                               class="btn btn-primary btn-block">
                                <i class="fas fa-edit"></i> Chỉnh sửa
                            </a>
                            <a href="@Url.Action("InstructorList", "Account", new { area = "Admin" })" 
                               class="btn btn-secondary btn-block">
                                <i class="fas fa-arrow-left"></i> Quay lại
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card card-info">
                    <div class="card-header">
                        <h3 class="card-title">Thông Tin Chi Tiết</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Tên đầy đủ</label>
                                    <p>@Model.FullName</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Email</label>
                                    <p>@Model.Email</p>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Số điện thoại</label>
                                    <p>@Model.PhoneNumber</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Bộ môn</label>
                                    <p>@Model.Department</p>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Môn học chuyên trách</label>
                                    <p>@Model.SpecializedSubject</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Mã nhân viên</label>
                                    <p>@Model.EmployeeCode</p>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Ngày bắt đầu làm việc</label>
                                    <p>@Model.HireDate.ToString("dd/MM/yyyy")</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Ngày cập nhật</label>
                                    <p>@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa cập nhật")</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>