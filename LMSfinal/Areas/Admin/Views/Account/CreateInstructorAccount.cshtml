@using LMSfinal.Models.ViewModels
@model CreateInstructorVM
@{
    ViewData["Title"] = "Tạo Tài Khoản Instructor";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid d-flex justify-content-center">
        <div class="col-md-8">
            <div class="card card-primary shadow-sm">
                <div class="card-header text-center bg-success">
                    <h3 class="card-title w-100 text-white">
                        <i class="fas fa-chalkboard-user mr-2"></i> Tạo Tài Khoản Instructor
                    </h3>
                </div>

                <div class="card-body">
                    @if (TempData["success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <!-- 🔥 HIỂN THỊ ROLE ĐÃ CHỌN -->
                    @if (ViewBag.Roles != null && ((IEnumerable<SelectListItem>)ViewBag.Roles).Any())
                    {
                        var selectedRole = ((IEnumerable<SelectListItem>)ViewBag.Roles).FirstOrDefault();
                        <div class="alert alert-info alert-dismissible fade show" role="alert">
                            <i class="fas fa-info-circle"></i> <strong>Vai trò được gán:</strong>
                            <span class="badge bg-success">@(selectedRole?.Text ?? "Chưa xác định")</span>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-area="Admin"
                          asp-controller="Account"
                          asp-action="CreateInstructorAccount"
                          method="post">

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-user mr-1"></i> Tên User <span class="text-danger">*</span></label>
                                    <input asp-for="UserName" class="form-control" placeholder="Nhập tên user" />
                                    <span asp-validation-for="UserName" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-id-card mr-1"></i> Tên đầy đủ <span class="text-danger">*</span></label>
                                    <input asp-for="FullName" class="form-control" placeholder="Nhập tên đầy đủ" />
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-envelope mr-1"></i> Email <span class="text-danger">*</span></label>
                                    <input asp-for="Email" type="email" class="form-control" placeholder="example@gmail.com" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-lock mr-1"></i> Mật khẩu <span class="text-danger">*</span></label>
                                    <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu (tối thiểu 6 ký tự)" />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-3" />
                        <h5 class="mb-3"><i class="fas fa-info-circle text-success"></i> Thông Tin Giáo Viên</h5>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-phone mr-1"></i> Số Điện Thoại <span class="text-danger">*</span></label>
                                    <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="0xxxxxxxxx" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-building mr-1"></i> Bộ Môn/Khoa <span class="text-danger">*</span></label>
                                    <input asp-for="Department" class="form-control" placeholder=" Công Nghệ Thông Tin" />
                                    <span asp-validation-for="Department" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-book mr-1"></i> Môn Học Chuyên Trách <span class="text-danger">*</span></label>
                                    <input asp-for="SpecializedSubject" class="form-control" placeholder="Lĩnh Vực" />
                                    <span asp-validation-for="SpecializedSubject" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-barcode mr-1"></i> Mã Nhân Viên</label>
                                    <input asp-for="EmployeeCode" class="form-control" placeholder="Để trống để auto-generate" />
                                    <span asp-validation-for="EmployeeCode" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-calendar mr-1"></i> Ngày Bắt Đầu Làm Việc <span class="text-danger">*</span></label>
                                    <input asp-for="HireDate" type="date" class="form-control" />
                                    <span asp-validation-for="HireDate" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- 🔥 DROPDOWN CHỌN ROLE -->
                        <div class="form-group">
                            <label><i class="fas fa-shield-alt mr-1"></i> Chọn Vai Trò <span class="text-danger">*</span></label>
                            <select asp-for="RoleId" class="form-control" asp-items="ViewBag.Roles">
                                <option value="">-- Chọn vai trò --</option>
                            </select>
                            <span asp-validation-for="RoleId" class="text-danger small"></span>
                            <small class="form-text text-muted"><i class="fas fa-info-circle"></i> Tài khoản này sẽ được gán role Instructor</small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="fas fa-user-plus"></i> Tạo Tài Khoản
                            </button>

                            <a asp-area="Admin" asp-controller="Account" asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="fas fa-arrow-left"></i> Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>