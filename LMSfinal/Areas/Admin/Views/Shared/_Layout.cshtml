<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width:device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS System</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/lms-shared.css" asp-append-version="true" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    
</head>
@using LMSfinal.Data
@using LMSfinal.Models.EF
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext
<body>
    <div id="pageLoader">
        <div class="spinner-border text-light"></div>
    </div>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 p-0 sidebar">
                <div class="sidebar-header text-center">
                    @if (User.IsInRole("Admin"))
                    {
                        <span>ADMIN PANEL</span>
                    }
                    else if (User.IsInRole("Instructor"))
                    {

                        <span>INSTRUCTOR</span>
                    }
                    else
                    {

                        <span>STUDENT PORTAL</span>
                    }

                    <!-- Avatar -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="mt-3 mb-3">
                            @{
                                var avatarUrl = "~/images/avatars/default-avatar.png";
                                var currentUser = await UserManager.GetUserAsync(User);

                                if (User.IsInRole("Instructor") && currentUser != null)
                                {
                                    var instructor = await DbContext.Instructors
                                    .FirstOrDefaultAsync(x => x.UserId == currentUser.Id);
                                    if (instructor?.ProfileImageUrl != null)
                                    {
                                        avatarUrl = instructor.ProfileImageUrl;
                                    }
                                }
                                else if (User.IsInRole("Student") && currentUser != null)
                                {
                                    var userProfile = await DbContext.UserProfiles
                                    .FirstOrDefaultAsync(x => x.UserId == currentUser.Id);
                                    if (userProfile?.ProfilePictureUrl != null)
                                    {
                                        avatarUrl = userProfile.ProfilePictureUrl;
                                    }
                                }
                                else if (currentUser?.Avatar != null)
                                {
                                    avatarUrl = currentUser.Avatar;
                                }
                            }

                            <img src="@avatarUrl"
                                 alt="@User.Identity.Name"
                                 class="rounded-circle border border-2 border-secondary"
                                 style="width: 80px; height: 80px; object-fit: cover; display: block; margin: 0 auto;" />
                            <small class="d-block mt-2 text-muted">@User.Identity.Name</small>
                        </div>
                    }
                </div>

                <div class="mt-3">
                    @if (User.IsInRole("Admin"))
                    {
                        var adminUser = await UserManager.GetUserAsync(User);
                        var adminNotificationCount = adminUser == null
                        ? 0
                        : await DbContext.Notifications.CountAsync(n => n.RecipientUserId == adminUser.Id && !n.IsRead);

                        <a asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
                        <a asp-area="Admin" asp-controller="Notification" asp-action="Index">
                            <i class="fa-solid fa-bell"></i> Thông báo
                            @if (adminNotificationCount > 0)
                            {
                                <span class="badge bg-danger ms-2">@adminNotificationCount</span>
                            }
                        </a>
                        <a asp-area="Admin" asp-controller="Account" asp-action="Index"><i class="fa-solid fa-users"></i> Quản lý Tài khoản</a>
                        <a asp-area="Admin" asp-controller="Role" asp-action="Index"><i class="fa-solid fa-user-shield"></i> Phân quyền</a>
                        <a asp-area="Admin" asp-controller="Category" asp-action="Index"><i class="fa-solid fa-layer-group"></i> Ngành học</a>
                        <a asp-area="Admin" asp-controller="Course" asp-action="Index"><i class="fa-solid fa-book"></i> Môn học</a>
                        <a asp-area="Admin" asp-controller="Pricing" asp-action="Index"><i class="fa-solid fa-money-bill-wave"></i> Giá tín chỉ</a>
                        <a asp-area="Admin" asp-controller="Classroom" asp-action="Index"><i class="fa-solid fa-school"></i> Lớp học</a>
                        <a asp-area="Admin" asp-controller="Account" asp-action="StudentList">
                            <i class="fa-solid fa-user-graduate"></i> Danh Sách Student
                        </a>
                        <a asp-area="Admin" asp-controller="Account" asp-action="InstructorList">
                            <i class="fa-solid fa-chalkboard-user"></i> Danh Sách Instructor
                        </a>
                        <a asp-area="Admin" asp-controller="FinalExamAdmin" asp-action="Index"><i class="fa-solid fa-school"></i>Tạo lịch thi</a>
                        <a asp-area="Admin" asp-controller="Payment" asp-action="Index"><i class="fa-solid fa-money-check-dollar"></i> Thanh toán</a>
                    }

                    <!-- Thêm vào _Layout.cshtml phần Instructor -->
                    @if (User.IsInRole("Instructor"))
                    {
                        var instructorUser = await UserManager.GetUserAsync(User);
                        var instructorNotificationCount = instructorUser == null
                            ? 0
                            : await DbContext.Notifications.CountAsync(n => n.RecipientUserId == instructorUser.Id && !n.IsRead);

                        <a asp-area="Instructor" asp-controller="HomeInstructor" asp-action="Index">
                            <i class="fa-solid fa-house"></i> Dashboard
                        </a>
                        <a asp-area="Instructor" asp-controller="Classroom" asp-action="Index">
                            <i class="fa-solid fa-chalkboard-user"></i> Lớp dạy của tôi
                        </a>
                        <a asp-area="Instructor" asp-controller="Quiz" asp-action="Index">
                            <i class="fa-solid fa-question-circle"></i> Quản lý Quiz
                        </a>
                        <a asp-area="Instructor" asp-controller="ScheduleTeach" asp-action="Index">
                            <i class="fa-solid fa-calendar"></i> Thời khóa biểu
                        </a>
                        <a asp-area="Instructor" asp-controller="Assignment" asp-action="Index">
                            <i class="fa-solid fa-file-lines"></i> Bài Tập
                        </a>
                        <a asp-area="Instructor" asp-controller="Classroom" asp-action="OverallAttendanceHistory">
                            <i class="fa-solid fa-clipboard-list"></i> Lịch sử điểm danh
                        </a>
                        <a asp-area="Instructor" asp-controller="Score" asp-action="Index">
                            <i class="fa-solid fa-clipboard-list"></i> Nhập điểm
                        </a>
                        <a asp-area="" asp-controller="Register" asp-action="AvailableClassroomsForInstructor">
                            <i class="fa-solid fa-clipboard-list"></i> Đăng ký lớp dạy
                        </a>
                        <a asp-area="Instructor" asp-controller="FinalExamInstructor" asp-action="Index">
                            <i class="fa-solid fa-clipboard-list"></i> Xem lịch giám sát thi
                        </a>
                        <a asp-area="Instructor" asp-controller="Notification" asp-action="Index">
                            <i class="fa-solid fa-bell"></i> Thông báo
                            @if (instructorNotificationCount > 0)
                            {
                                <span class="badge bg-danger ms-2">@instructorNotificationCount</span>
                            }
                        </a>
                    }
                    }
                    @if (User.IsInRole("Student"))
                    {
                        var currentUser = await UserManager.GetUserAsync(User);
                        var notificationCount = currentUser == null
                        ? 0
                        : await DbContext.Notifications.CountAsync(n => n.RecipientUserId == currentUser.Id && !n.IsRead);

                        <a asp-area="Student" asp-controller="HomeStudent" asp-action="Index"><i class="fa-solid fa-house-user"></i> Dashboard</a>
                        <a asp-area="Student" asp-controller="CourseStudent" asp-action="Index"><i class="fa-solid fa-book"></i> Lớp Học</a>
                        <a asp-area="Student" asp-controller="Schedule" asp-action="MySchedule"><i class="fa-solid fa-calendar-days"></i> Lịch học</a>
                        <a asp-area="Student" asp-controller="Assignment" asp-action="Index"><i class="fa-solid fa-tasks"></i> Bài Tập</a>
                        <a asp-area="Student" asp-controller="Notification" asp-action="Index">
                            <i class="fa-solid fa-bell"></i> Thông báo
                            @if (notificationCount > 0)
                            {
                                <span class="badge bg-danger ms-2">@notificationCount</span>
                            }
                        </a>
                        <a asp-area="Student" asp-controller="Attendance" asp-action="MyAttendanceHistory"><i class="fa-solid fa-calendar-days"></i> Lịch sử điểm danh</a>
                        <a asp-area="Student" asp-controller="Profile" asp-action="Index"><i class="fa-solid fa-address-card"></i> Hồ sơ cá nhân</a>
                        <a asp-area="Student" asp-controller="Grade" asp-action="Index" class="ajax-link"><i class="fa-solid fa-address-card"></i> Xem điểm</a>
                        <a asp-area="" asp-controller="Register" asp-action="AvailableClassroomsForStudent">
                            <i class="fa-solid fa-clipboard-list"></i> Đăng ký lớp học
                        </a>
                        <a asp-area="Student" asp-controller="Payment" asp-action="Index"><i class="fa-solid fa-credit-card"></i> Thanh toán</a>
                    }

                    <hr class="mx-3 text-secondary">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-area="Admin" asp-controller="ProfilePersonal" asp-action="Index" class="profile-btn">
                            <i class="fa-solid fa-user"></i> Hồ sơ cá nhân
                        </a>
                        @* <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline;">
                            <button type="submit" class="logout-btn border-0 bg-transparent">
                                <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
                            </button>
                        </form> *@
                        <a asp-area="Admin" asp-controller="Account" asp-action="Logout" class="logout-btn">
                            <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="nav-link">
                            <i class="fa-solid fa-right-to-bracket"></i> Đăng nhập
                        </a>
                    }

                </div>
            </nav>

            <main class="col-md-9 col-lg-10 p-0">
                <div class="d-flex justify-content-between align-items-center p-3 px-4 border-bottom bg-white">
                    <h5 class="m-0 text-secondary">@ViewData["Title"]</h5>
                    <div class="user-info d-flex align-items-center gap-3">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <!-- Avatar -->
                            <div class="avatar-container">
                                @{
                                    var topAvatarUrl = "~/images/avatars/default-avatar.png";
                                    var topUser = await UserManager.GetUserAsync(User);

                                    if (User.IsInRole("Instructor") && topUser != null)
                                    {
                                        var topInstructor = await DbContext.Instructors
                                        .FirstOrDefaultAsync(x => x.UserId == topUser.Id);
                                        if (topInstructor?.ProfileImageUrl != null)
                                        {
                                            topAvatarUrl = topInstructor.ProfileImageUrl;
                                        }
                                    }
                                    else if (User.IsInRole("Student") && topUser != null)
                                    {
                                        var topUserProfile = await DbContext.UserProfiles
                                        .FirstOrDefaultAsync(x => x.UserId == topUser.Id);
                                        if (topUserProfile?.ProfilePictureUrl != null)
                                        {
                                            topAvatarUrl = topUserProfile.ProfilePictureUrl;
                                        }
                                    }
                                    else if (topUser?.Avatar != null)
                                    {
                                        topAvatarUrl = topUser.Avatar;
                                    }
                                }

                                <img src="@topAvatarUrl"
                                     alt="@User.Identity.Name"
                                     class="rounded-circle border border-secondary"
                                     style="width: 40px; height: 40px; object-fit: cover;" />
                            </div>
                        }
                        <span class="badge bg-info text-dark">Xin chào, @User.Identity.Name</span>
                    </div>
                </div>

                <div class="main-content p-4">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>
    <script>

        document.addEventListener("DOMContentLoaded", () => {

            // =========================
            // Sidebar Active Menu
            // =========================
            $('.sidebar a').on('click', function () {
                $('.sidebar a').removeClass('active');
                $(this).addClass('active');
            });

            // =========================
            // Page Transition + Loader
            // =========================
            document.querySelectorAll("a").forEach(link => {

                link.addEventListener("click", function (e) {

                    const href = this.getAttribute("href");

                    if (
                        !href ||
                        href.startsWith("#") ||
                        href.startsWith("javascript:") ||
                        href.startsWith("mailto:")
                    ) {
                        return;
                    }

                    e.preventDefault();

                    document.body.classList.add("page-exit");

                    const loader = document.getElementById("pageLoader");

                    if (loader) {
                        loader.classList.add("show");
                    }

                    setTimeout(() => {
                        window.location.href = href;
                    }, 200);
                });
            });

        });


        // =========================
        // SignalR Notification
        // =========================

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .configureLogging(signalR.LogLevel.Information)
            .build();

        connection.on("ReceiveNotification", function (message) {

            console.log("🔔 Notification Received:");
            console.log(message);

            document.dispatchEvent(
                new CustomEvent("notification:received", {
                    detail: message
                })
            );
        });

        connection.onreconnecting(error => {
            console.warn("SignalR reconnecting...", error);
        });

        connection.onreconnected(connectionId => {
            console.log("SignalR reconnected:", connectionId);
        });

        connection.onclose(error => {
            console.error("SignalR closed:", error);
        });

        async function startSignalR() {

            try {

                await connection.start();

                console.log("✅ SignalR Connected");
                console.log("ConnectionId:", connection.connectionId);

            } catch (err) {

                console.error("❌ SignalR Connection Failed");
                console.error(err);

            }
        }

        startSignalR();

    </script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>