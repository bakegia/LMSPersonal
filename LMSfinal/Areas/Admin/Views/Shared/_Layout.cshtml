@using DocumentFormat.OpenXml.Wordprocessing
@using LMSfinal.Data
@using LMSfinal.Models.EF
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var topAvatarUrl = "~/images/avatars/default-avatar.png";
    var adminUser = await UserManager.GetUserAsync(User);
    var adminNotificationCount = adminUser == null
        ? 0
        : await DbContext.Notifications.CountAsync(n => n.RecipientUserId == adminUser.Id && !n.IsRead);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS Instructor</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/lms-shared.css" asp-append-version="true" />
</head>
<body>

    <div id="pageLoader">
        <div class="spinner-border text-light"></div>
    </div>

    <!-- Sidebar -->
    <aside class="sidebar-instructor">

        <div class="sidebar-header">

            <strong>ADMIN PANEL</strong>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="avatar-box">
                    @{
                        var avatarUrl = "~/images/avatars/default-avatar.png";
                        var currentUser = await UserManager.GetUserAsync(User);

                        if (currentUser?.Avatar != null)
                            avatarUrl = currentUser.Avatar;
                    }

                    <img src="@avatarUrl" class="rounded-circle" />

                    <div class="user-name">
                        @User.Identity.Name
                    </div>
                </div>
            }

        </div>

        <nav class="sidebar-nav">

            <a asp-area="Admin"
               asp-controller="HomeAdmin"
               asp-action="Index"
               class="sidebar-link @(controller == "HomeAdmin" ? "active" : "")">
                <i class="fa-solid fa-chart-line"></i>
                Dashboard
            </a>

            <a asp-area="Admin"
               asp-controller="Notification"
               asp-action="Index"
               class="sidebar-link @(controller=="Notification" ? "active" : "")">
                <i class="fa-solid fa-bell"></i>
                Thông báo

                @if (adminNotificationCount > 0)
                {
                    <span class="badge bg-danger ms-2">
                        @adminNotificationCount
                    </span>
                }
            </a>

            <a asp-area="Admin"
               asp-controller="Account"
               asp-action="Index"
               class="sidebar-link @(controller == "Account" && action == "Index" ? "active" : "")">
                <i class="fa-solid fa-users"></i>
                Quản lý tài khoản
            </a>

            <a asp-area="Admin"
               asp-controller="Role"
               asp-action="Index"
               class="sidebar-link @(controller == "Role" ? "active" : "")">
                <i class="fa-solid fa-user-shield"></i>
                Phân quyền
            </a>

            <a asp-area="Admin"
               asp-controller="Category"
               asp-action="Index"
               class="sidebar-link @(controller == "Category" ? "active" : "")">
                <i class="fa-solid fa-layer-group"></i>
                Ngành học
            </a>

            <a asp-area="Admin"
               asp-controller="Course"
               asp-action="Index"
               class="sidebar-link @(controller == "Course" ? "active" : "")">
                <i class="fa-solid fa-book"></i>
                Môn học
            </a>

            <a asp-area="Admin"
               asp-controller="Pricing"
               asp-action="Index"
               class="sidebar-link @(controller == "Pricing" ? "active" : "")">
                <i class="fa-solid fa-money-bill-wave"></i>
                Giá tín chỉ
            </a>

            <a asp-area="Admin"
               asp-controller="Classroom"
               asp-action="Index"
               class="sidebar-link @(controller == "Classroom" ? "active" : "")">
                <i class="fa-solid fa-school"></i>
                Lớp học
            </a>

            <a asp-area="Admin"
               asp-controller="Account"
               asp-action="StudentList"
               class="sidebar-link @(action == "StudentList" ? "active" : "")">
                <i class="fa-solid fa-user-graduate"></i>
                Danh sách Student
            </a>

            <a asp-area="Admin"
               asp-controller="Account"
               asp-action="InstructorList"
               class="sidebar-link @(action == "InstructorList" ? "active" : "")">
                <i class="fa-solid fa-chalkboard-user"></i>
                Danh sách Instructor
            </a>

            <a asp-area="Admin"
               asp-controller="FinalExamAdmin"
               asp-action="Index"
               class="sidebar-link @(controller == "FinalExamAdmin" ? "active" : "")">
                <i class="fa-solid fa-clipboard-list"></i>
                Tạo lịch thi
            </a>

            <a asp-area="Admin"
               asp-controller="Payment"
               asp-action="Index"
               class="sidebar-link @(controller == "Payment" ? "active" : "")">
                <i class="fa-solid fa-money-check-dollar"></i>
                Thanh toán
            </a>

            <hr />

            <a asp-area="Admin"
               asp-controller="ProfilePersonal"
               asp-action="Index"
               class="sidebar-link">
                <i class="fa-solid fa-user"></i>
                Hồ sơ
            </a>

            <a asp-area="Admin"
               asp-controller="Account"
               asp-action="Logout"
               class="sidebar-link text-danger">
                <i class="fa-solid fa-right-from-bracket"></i>
                Đăng xuất
            </a>

        </nav>

    </aside>

    <!-- Main -->
    <div class="main-wrapper">

        <header class="main-header">

            <h5 class="page-title">
                @ViewData["Title"]
            </h5>

            <div class="user-info">

                <img src="@topAvatarUrl"
                     class="rounded-circle header-avatar" />

                <span>
                    Xin chào, @User.Identity?.Name
                </span>

            </div>

        </header>

        <main class="main-content">
            @RenderBody()
        </main>

    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const sidebar = document.querySelector(".sidebar-instructor");

            if (!sidebar) return;

            // Khôi phục vị trí scroll
            const savedPosition = sessionStorage.getItem("sidebarScroll");

            if (savedPosition) {
                sidebar.scrollTop = parseInt(savedPosition);
            }

            // Lưu vị trí scroll
            sidebar.addEventListener("scroll", function () {
                sessionStorage.setItem(
                    "sidebarScroll",
                    sidebar.scrollTop
                );
            });

        });
    </script>
    <script>
        document.querySelectorAll(".sidebar-link").forEach(link => {

            link.addEventListener("click", function () {

                const sidebar =
                    document.querySelector(".sidebar-student");

                sessionStorage.setItem(
                    "sidebarScroll",
                    sidebar.scrollTop
                );

            });

        });
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>