@using LMSfinal.Models.ViewModels.Student
@model StudentAssignmentViewDetailViewModel
@{
    ViewData["Title"] = $"Chi tiết: {Model.AssignmentDetail.Title}";
    Layout = "~/Areas/Student/Views/Shared/_Layout.cshtml";
}

<style>
    .submission-timeline {
        position: relative;
        padding-left: 40px;
    }

        .submission-timeline::before {
            content: '';
            position: absolute;
            left: 10px;
            top: 0;
            bottom: 0;
            width: 2px;
            background-color: #dee2e6;
        }

    .submission-item {
        position: relative;
        margin-bottom: 20px;
        padding-bottom: 20px;
    }

        .submission-item::before {
            content: '';
            position: absolute;
            left: -34px;
            top: 5px;
            width: 14px;
            height: 14px;
            background-color: #0d6efd;
            border-radius: 50%;
            border: 3px solid white;
        }

    .content-box {
        background-color: #f8f9fa;
        border-left: 4px solid #0d6efd;
        padding: 15px;
        border-radius: 4px;
        margin: 15px 0;
    }

    .status-badge {
        font-size: 1rem;
        padding: 8px 16px;
    }
</style>

<div class="container-fluid">
    <!-- Header -->
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
        <h2>@Model.AssignmentDetail.Title</h2>
        <p class="text-muted">@Model.AssignmentDetail.CourseTitle</p>
    </div>

    <div class="row">
        <!-- Cột chính -->
        <div class="col-lg-8">
            <!-- Thông tin bài tập -->
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fa-solid fa-file-lines"></i> Thông Tin Bài Tập
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">@Model.AssignmentDetail.Description</p>

                    <!-- Nội dung chi tiết -->
                    @if (!string.IsNullOrEmpty(Model.AssignmentDetail.Content))
                    {
                        <div class="content-box">
                            <strong>Yêu cầu & Hướng dẫn:</strong>
                            <div class="mt-3">
                                @Html.Raw(Model.AssignmentDetail.Content)
                            </div>
                        </div>
                    }

                    <!-- Hạn chót -->
                    <div class="alert @(Model.IsOverdue ? "alert-danger" : "alert-info") mt-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>Hạn chót:</strong>
                                @Model.AssignmentDetail.DueDate.ToString("dd/MM/yyyy HH:mm:ss")
                            </div>
                            @if (Model.IsOverdue)
                            {
                                <span class="badge bg-danger status-badge">
                                    <i class="fa-solid fa-exclamation-triangle"></i> Quá Hạn
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success status-badge">
                                    <i class="fa-solid fa-clock"></i> Còn Hạn
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bài nộp của tôi -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fa-solid fa-file-export"></i> Lịch Sử Nộp Bài
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Submissions.Any())
                    {
                        <div class="submission-timeline">
                            @foreach (var submission in Model.Submissions)
                            {
                                <div class="submission-item">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <strong>Nộp lần @(Model.Submissions.IndexOf(submission) + 1)</strong>
                                            <br />
                                            <small class="text-muted">
                                                @submission.SubmittedAt.ToString("dd/MM/yyyy HH:mm:ss")
                                            </small>
                                        </div>
                                        @if (submission.IsLate)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fa-solid fa-clock"></i> Nộp Trễ
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                <i class="fa-solid fa-check"></i> Đúng Hạn
                                            </span>
                                        }
                                    </div>

                                    <!-- Nội dung -->
                                    <div class="bg-light p-3 rounded mb-3">
                                        <p>@submission.SubmissionText</p>
                                    </div>

                                    <!-- File đính kèm -->
                                    @if (!string.IsNullOrEmpty(submission.AttachmentUrl))
                                    {
                                        <div class="mb-3">
                                            <a href="@submission.AttachmentUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                                <i class="fa-solid fa-download"></i> Tải xuống File
                                            </a>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fa-solid fa-exclamation-circle"></i> Bạn chưa nộp bài tập này
                        </div>
                    }
                </div>
                @if (!Model.AssignmentDetail.IsSubmitted)
                {
                    <div class="card-footer bg-light">
                        <a asp-area="Student" asp-controller="Assignment" asp-action="Submit"
                           asp-route-studentAssignmentId="@ViewBag.StudentAssignmentId"
                           class="btn btn-primary w-100">
                            <i class="fa-solid fa-paper-plane"></i> Nộp Bài Tập
                        </a>
                    </div>
                }
                else
                {
                    <div class="card-footer bg-light">
                        <a asp-area="Student" asp-controller="Assignment" asp-action="Submit"
                           asp-route-studentAssignmentId="@ViewBag.StudentAssignmentId"
                           class="btn btn-warning w-100">
                            <i class="fa-solid fa-pen"></i> Sửa & Nộp Lại
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Trạng thái -->
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">
                        <i class="fa-solid fa-info-circle"></i> Trạng Thái
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.AssignmentDetail.IsSubmitted)
                    {
                        <div class="alert alert-success mb-0">
                            <i class="fa-solid fa-check-circle"></i> <strong>Đã Nộp</strong>
                            <br />
                            <small>
                                @if (Model.IsLateSubmission)
                                {
                                    <span class="text-warning">Nộp Trễ Hạn</span>
                                }
                                else
                                {
                                    <span>Nộp Đúng Hạn</span>
                                }
                            </small>
                        </div>
                    }
                    else
                    {
                        @if (Model.IsOverdue)
                        {
                            <div class="alert alert-danger mb-0">
                                <i class="fa-solid fa-exclamation-triangle"></i> <strong>Quá Hạn</strong>
                                <br />
                                <small>Hạn chót đã qua. Bạn vẫn có thể nộp nhưng sẽ bị tính là nộp trễ.</small>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-0">
                                <i class="fa-solid fa-hourglass-end"></i> <strong>Chưa Nộp</strong>
                                <br />
                                <small>Bạn cần nộp bài để hoàn thành bài tập này.</small>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Điểm số -->
            @if (!string.IsNullOrEmpty(Model.AssignmentDetail.Score))
            {
                <div class="card shadow-sm mb-4 border-0 bg-success text-white">
                    <div class="card-header" style="background-color: rgba(0,0,0,0.1); border-color: rgba(0,0,0,0.1);">
                        <h5 class="mb-0">
                            <i class="fa-solid fa-star"></i> Điểm Số
                        </h5>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0">@Model.AssignmentDetail.Score</h2>
                        <small>Được chấm bởi giáo viên</small>
                    </div>
                </div>
            }

            <!-- Thông tin khác -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fa-solid fa-details"></i> Chi Tiết
                    </h5>
                </div>
                <div class="card-body">
                    <dl>
                        <dt class="text-muted small">Trạng thái</dt>
                        <dd>
                            @if (Model.AssignmentDetail.IsSubmitted)
                            {
                                <span class="badge bg-success">Đã Nộp</span>
                            }
                            else if (Model.IsOverdue)
                            {
                                <span class="badge bg-danger">Quá Hạn</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Chưa Nộp</span>
                            }
                        </dd>

                        @if (Model.AssignmentDetail.SubmittedAt.HasValue)
                        {
                            <dt class="text-muted small mt-3">Nộp lúc</dt>
                            <dd>@Model.AssignmentDetail.SubmittedAt.Value.ToString("dd/MM/yyyy HH:mm:ss")</dd>
                        }

                        <dt class="text-muted small mt-3">Hạn chót</dt>
                        <dd>@Model.AssignmentDetail.DueDate.ToString("dd/MM/yyyy HH:mm:ss")</dd>

                        @if (Model.Submissions.Any())
                        {
                            <dt class="text-muted small mt-3">Số lần nộp</dt>
                            <dd>@Model.Submissions.Count</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Lưu studentAssignmentId vào ViewBag (từ URL hoặc từ dữ liệu)
        document.addEventListener('DOMContentLoaded', function() {
            // ID này sẽ được lấy từ parameter
        });
    </script>
}