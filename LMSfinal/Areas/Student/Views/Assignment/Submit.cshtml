@using LMSfinal.Models.ViewModels.Student
@model StudentAssignmentSubmitViewModel
@{
    ViewData["Title"] = "Nộp Bài Tập";
    Layout = "~/Areas/Student/Views/Shared/_Layout.cshtml";
}

<style>
    .editor-section {
        border: 1px solid #dee2e6;
        border-radius: 6px;
        overflow: hidden;
    }

    .editor-toolbar {
        background-color: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
        padding: 10px;
    }

    .editor-content {
        min-height: 300px;
        padding: 15px;
    }

    .file-upload-area {
        border: 2px dashed #0d6efd;
        border-radius: 6px;
        padding: 30px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
        background-color: #f8f9ff;
    }

        .file-upload-area:hover {
            background-color: #e7f1ff;
            border-color: #084298;
        }

        .file-upload-area.dragover {
            background-color: #cfe2ff;
            border-color: #084298;
        }
</style>

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="mb-4">
                <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm mb-3">
                    <i class="fa-solid fa-arrow-left"></i> Quay lại
                </a>
                <h2>Nộp Bài Tập: @Model.AssignmentTitle</h2>
                <p class="text-muted">@Model.CourseTitle</p>
            </div>

            <!-- Alert -->
            @if (Model.DueDate < DateTime.Now)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <i class="fa-solid fa-exclamation-triangle"></i>
                    <strong>Chú ý!</strong> Bài tập này đã quá hạn. Nộp bài sẽ được tính là nộp trễ hạn.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.HasPreviousSubmission)
            {
                <div class="alert alert-info alert-dismissible fade show mb-4" role="alert">
                    <i class="fa-solid fa-info-circle"></i>
                    <strong>Thông Báo:</strong> Bạn đã nộp bài trước đây. Nộp lại sẽ ghi đè bài cũ.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Thông tin bài tập -->
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fa-solid fa-file-lines"></i> Nội Dung Bài Tập
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">@Model.Description</p>

                    @if (!string.IsNullOrEmpty(Model.Content))
                    {
                        <div class="bg-light p-3 rounded">
                            <strong>Yêu cầu chi tiết:</strong>
                            <div class="mt-3">
                                @Html.Raw(Model.Content)
                            </div>
                        </div>
                    }

                    <div class="alert alert-warning mt-3 mb-0">
                        <small>
                            <strong>Hạn chót:</strong> @Model.DueDate.ToString("dd/MM/yyyy HH:mm:ss")
                        </small>
                    </div>
                </div>
            </div>

            <!-- Form nộp bài -->
            <form asp-action="Submit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="StudentAssignmentId" />
                <input type="hidden" asp-for="AssignmentId" />
                <input type="hidden" asp-for="CourseTitle" />
                <input type="hidden" asp-for="AssignmentTitle" />
                <input type="hidden" asp-for="Description" />
                <input type="hidden" asp-for="Content" />
                <input type="hidden" asp-for="DueDate" />
                <input type="hidden" asp-for="HasPreviousSubmission" />
                <input type="hidden" asp-for="PreviousSubmissionText" />

                <!-- Nội dung bài nộp -->
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fa-solid fa-pen"></i> Nội Dung Bài Nộp
                        </h5>
                    </div>
                    <div class="card-body">
                        <label asp-for="SubmissionText" class="form-label fw-bold">
                            Nhập bài tập của bạn
                        </label>
                        <textarea asp-for="SubmissionText" class="form-control" rows="10"
                                  placeholder="Viết câu trả lời, mã code, hoặc nội dung bài tập tại đây..."></textarea>
                        <span asp-validation-for="SubmissionText" class="text-danger small d-block mt-2"></span>
                        <small class="text-muted d-block mt-2">
                            <i class="fa-solid fa-info-circle"></i> Hỗ trợ plain text. Nếu cần định dạng đặc biệt, vui lòng sử dụng file đính kèm.
                        </small>
                    </div>
                </div>

                <!-- File đính kèm -->
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="fa-solid fa-paperclip"></i> Tệp Đính Kèm (Không Bắt Buộc)
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="file-upload-area" id="dropZone">
                            <i class="fa-solid fa-cloud-arrow-up fa-2x mb-3 text-primary d-block"></i>
                            <p class="mb-2">Kéo thả file tại đây hoặc</p>
                            <label for="AttachmentFile" class="btn btn-outline-primary">
                                <i class="fa-solid fa-folder-open"></i> Chọn File
                            </label>
                            <input type="file" id="AttachmentFile" asp-for="AttachmentFile" class="d-none" />
                            <p class="text-muted small mt-2 mb-0">
                                Hỗ trợ: PDF, Word, Image, Code (max 10MB)
                            </p>
                        </div>
                        <div id="fileName" class="mt-3 d-none">
                            <span class="badge bg-success">
                                <i class="fa-solid fa-check"></i> <span id="nameText"></span>
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Nộp bài -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="confirmCheck" required>
                            <label class="form-check-label" for="confirmCheck">
                                Tôi xác nhận rằng đây là bài làm của riêng tôi và tôi đồng ý với các điều khoản của trường
                            </label>
                        </div>

                        <div class="d-flex gap-2 justify-content-between">
                            <a href="javascript:history.back()" class="btn btn-secondary btn-lg">
                                <i class="fa-solid fa-times"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                                <i class="fa-solid fa-paper-plane"></i> Nộp Bài Tập
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <!-- Sidebar - Trợ Giúp -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fa-solid fa-circle-question"></i> Hướng Dẫn Nộp Bài
                    </h5>
                </div>
                <div class="card-body">
                    <ol class="ps-3">
                        <li class="mb-3">
                            <strong>Đọc kỹ yêu cầu</strong>
                            <p class="text-muted small">Xem phần "Nội Dung Bài Tập" ở trên để hiểu rõ yêu cầu</p>
                        </li>
                        <li class="mb-3">
                            <strong>Viết bài</strong>
                            <p class="text-muted small">Nhập câu trả lời hoặc code vào ô "Nội Dung Bài Nộp"</p>
                        </li>
                        <li class="mb-3">
                            <strong>Đính kèm tệp (nếu cần)</strong>
                            <p class="text-muted small">Tải lên file nếu bài tập yêu cầu</p>
                        </li>
                        <li class="mb-3">
                            <strong>Kiểm tra lại</strong>
                            <p class="text-muted small">Đảm bảo mọi thứ chính xác trước khi nộp</p>
                        </li>
                        <li>
                            <strong>Nộp bài</strong>
                            <p class="text-muted small">Nhấn nút "Nộp Bài Tập" để hoàn thành</p>
                        </li>
                    </ol>
                </div>
            </div>

            <!-- Lưu ý -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="fa-solid fa-triangle-exclamation"></i> Lưu Ý Quan Trọng
                    </h5>
                </div>
                <div class="card-body">
                    <ul class="ps-3 text-muted small">
                        <li class="mb-2">Nộp bài trước hạn chót để tránh bị trừ điểm</li>
                        <li class="mb-2">Nộp lại sẽ thay thế bài cũ</li>
                        <li class="mb-2">Đảm bảo nội dung rõ ràng và đúng chính tả</li>
                        <li>Bài tập sẽ được kiểm tra tự động hoặc bởi giáo viên</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Drag and drop
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('AttachmentFile');
        const fileNameDiv = document.getElementById('fileName');
        const fileNameText = document.getElementById('nameText');
        const submitBtn = document.getElementById('submitBtn');
        const confirmCheck = document.getElementById('confirmCheck');

        // Prevent default drag behaviors
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, preventDefaults, false);
            document.body.addEventListener(eventName, preventDefaults, false);
        });

        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }

        // Highlight drop area when item is dragged over it
        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.add('dragover'), false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.remove('dragover'), false);
        });

        // Handle dropped files
        dropZone.addEventListener('drop', (e) => {
            const dt = e.dataTransfer;
            const files = dt.files;
            fileInput.files = files;
            updateFileName();
        }, false);

        // Handle file input change
        fileInput.addEventListener('change', updateFileName);

        function updateFileName() {
            if (fileInput.files.length > 0) {
                fileNameText.textContent = fileInput.files[0].name;
                fileNameDiv.classList.remove('d-none');
            } else {
                fileNameDiv.classList.add('d-none');
            }
        }

        // Disable submit button until checkbox is checked
        submitBtn.disabled = true;
        confirmCheck.addEventListener('change', () => {
            submitBtn.disabled = !confirmCheck.checked;
        });
    </script>
}