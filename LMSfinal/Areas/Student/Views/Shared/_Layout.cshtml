@using LMSfinal.Data
@using LMSfinal.Models.EF
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS Student</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/student-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/lms-shared.css" asp-append-version="true" />
</head>
<style>

</style>
<body class="preloading">
    <div id="preload" class="preload-container text-center">
        <span class="glyphicon glyphicon-repeat preload-icon rotating"></span>
    </div>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="Student" asp-controller="HomeStudent" asp-action="Index">LMSfinal</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#studentNav" aria-controls="studentNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="studentNav">
                <form class="d-flex ms-3" role="search" asp-area="Student" asp-controller="CourseStudent" asp-action="Index">
                    <input class="form-control me-2 rounded" name="q" type="search" placeholder="Tìm khóa học" aria-label="Search">
                    <button class="btn btn-outline-light" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
                </form>

                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Student" asp-controller="HomeStudent" asp-action="Index">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Student" asp-controller="CourseStudent" asp-action="Index">Khóa học</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Student" asp-controller="Schedule" asp-action="MySchedule">Lịch học</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Student" asp-controller="Assignment" asp-action="Index">Bài Tập</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Student" asp-controller="Notification" asp-action="Index">
                            <i class="fa-solid fa-bell"></i> Thông báo
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="studentMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @{
                                    var avatar = "~/images/avatars/default-avatar.png";
                                    var u = await UserManager.GetUserAsync(User);
                                    if (u?.Avatar != null) { avatar = u.Avatar; }
                                }
                                <img src="@avatar" alt="avatar" class="rounded-circle" style="width:36px;height:36px;object-fit:cover;margin-right:8px;" />
                                @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="studentMenu">
                                <li><a class="dropdown-item" asp-area="Student" asp-controller="Profile" asp-action="Index">Hồ sơ</a></li>
                                <li><a class="dropdown-item" asp-area="Student" asp-controller="Payment" asp-action="Index">Thanh toán</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Account" asp-action="Logout">Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Auth" asp-action="Login">Đăng nhập</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 p-0 sidebar">
                <div class="sidebar-header text-center py-3">
                    <strong>CONTROL PANEL</strong>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="mt-3 mb-3">
                            @{
                                var avatar = "~/images/avatars/default-avatar.png";
                                var u = await UserManager.GetUserAsync(User);
                                if (u?.Avatar != null) { avatar = u.Avatar; }
                            }
                            <img src="@avatar" alt="@User.Identity.Name" class="rounded-circle" style="width:72px;height:72px;object-fit:cover;" />
                            <div class="small text-muted mt-2">@User.Identity.Name</div>
                        </div>
                    }
                </div>

                <div class="nav-links px-3">
                        @if (User.IsInRole("Student"))
                        {
                            var currentUser = await UserManager.GetUserAsync(User);
                            var notificationCount = currentUser == null
                            ? 0
                            : await DbContext.Notifications.CountAsync(n => n.RecipientUserId == currentUser.Id && !n.IsRead);

                            <a asp-area="Student" asp-controller="HomeStudent" asp-action="Index" class="d-block py-2">
                                <i class="fa-solid fa-house me-2"></i> Dashboard
                            </a>

                            <a asp-area="Student" asp-controller="CourseStudent" asp-action="Index" class="d-block py-2">
                                <i class="fa-solid fa-book me-2"></i> Lớp học
                            </a>

                            <a asp-area="Student" asp-controller="Schedule" asp-action="MySchedule" class="d-block py-2">
                                <i class="fa-solid fa-calendar-days me-2"></i> Lịch học
                            </a>

                            <a asp-area="Student" asp-controller="Assignment" asp-action="Index" class="d-block py-2">
                                <i class="fa-solid fa-tasks me-2"></i> Bài tập
                            </a>

                            <a asp-area="Student" asp-controller="Notification" asp-action="Index" class="d-block py-2">
                                <i class="fa-solid fa-bell me-2"></i> Thông báo
                                @if (notificationCount > 0)
                                {
                                    <span class="badge bg-danger ms-2">@notificationCount</span>
                                }
                            </a>

                            <a asp-area="Student" asp-controller="Attendance" asp-action="MyAttendanceHistory" class="d-block py-2">
                                <i class="fa-solid fa-calendar-check me-2"></i> Lịch sử điểm danh
                            </a>

                            <a asp-area="Student" asp-controller="Profile" asp-action="Index" class="d-block py-2">
                                <i class="fa-solid fa-address-card me-2"></i> Hồ sơ cá nhân
                            </a>

                            <a asp-area="Student" asp-controller="Grade" asp-action="Index" class="d-block py-2">
                                <i class="fa-solid fa-chart-line me-2"></i> Xem điểm
                            </a>

                            <a asp-area="" asp-controller="Register" asp-action="AvailableClassroomsForStudent" class="d-block py-2">
                                <i class="fa-solid fa-clipboard-list me-2"></i> Đăng ký lớp học
                            </a>

                            <a asp-area="Student" asp-controller="Payment" asp-action="Index" class="d-block py-2">
                                <i class="fa-solid fa-credit-card me-2"></i> Thanh toán
                            </a>
                        }

                    @* Instructor links for users in Instructor role *@
                    @if (User.IsInRole("Instructor"))
                    {
                        <hr />
                        <div class="small text-secondary px-1">Instructor</div>
                        <a asp-area="Instructor" asp-controller="HomeInstructor" asp-action="Index" class="d-block py-2"><i class="fa-solid fa-house me-2"></i> Dashboard</a>
                        <a asp-area="Instructor" asp-controller="Classroom" asp-action="Index" class="d-block py-2"><i class="fa-solid fa-chalkboard-user me-2"></i> Lớp dạy của tôi</a>
                        <a asp-area="Instructor" asp-controller="Quiz" asp-action="Index" class="d-block py-2"><i class="fa-solid fa-question-circle me-2"></i> Quản lý Quiz</a>
                        <a asp-area="Instructor" asp-controller="ScheduleTeach" asp-action="Index" class="d-block py-2"><i class="fa-solid fa-calendar me-2"></i> Thời khóa biểu</a>
                    }

                    @* Admin links for users in Admin role *@
                    @if (User.IsInRole("Admin"))
                    {
                        <hr />
                        <div class="small text-secondary px-1">Admin</div>
                        <a asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index" class="d-block py-2"><i class="fa-solid fa-chart-line me-2"></i> Dashboard</a>
                        <a asp-area="Admin" asp-controller="Account" asp-action="Index" class="d-block py-2"><i class="fa-solid fa-users me-2"></i> Quản lý Tài khoản</a>
                        <a asp-area="Admin" asp-controller="Course" asp-action="Index" class="d-block py-2"><i class="fa-solid fa-book me-2"></i> Môn học</a>
                    }

                    <hr />
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-area="Student" asp-controller="Profile" asp-action="Index" class="d-block py-2"><i class="fa-solid fa-user me-2"></i> Hồ sơ</a>
                        <a asp-area="Student" asp-controller="Account" asp-action="Logout" class="d-block py-2 text-danger"><i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất</a>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="d-block py-2">Đăng nhập</a>
                    }
                </div>
            </nav>

            <main id="main-content-area" class="col-md-9 col-lg-10 p-0">
                <div class="d-flex justify-content-between align-items-center p-3 px-4 border-bottom bg-white">
                    <h5 class="m-0 text-secondary">@ViewData["Title"]</h5>
                    <div class="user-info d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="avatar-container">
                                @{
                                    var topAvatarUrl = "~/images/avatars/default-avatar.png";
                                    var topUser = await UserManager.GetUserAsync(User);
                                    if (topUser?.Avatar != null) { topAvatarUrl = topUser.Avatar; }
                                }
                                <img src="@topAvatarUrl" alt="@User.Identity.Name" class="rounded-circle border border-secondary" style="width:40px;height:40px;object-fit:cover;" />
                            </div>
                        }
                        <span class="badge bg-info text-dark">Xin chào, @User.Identity?.Name</span>
                    </div>
                </div>

                <div class="main-content p-4">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>
    
    
    <footer class="bg-light text-center py-3 mt-auto">
        <div class="container">
            <small class="text-muted">© @DateTime.Now.Year LMSfinal</small>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(window).on('load', function () {
            $('#preload').fadeOut(300, function () {
                $('body').removeClass('preloading');
            });
        });
    </script>
    <script src="~/js/student-layout.js" asp-append-version="true"></script>
    <script>
        if (window.StudentLayout) {
            StudentLayout.init({
                contentSelector: '#main-content-area .main-content',
                linkSelector: '.nav-links a',
                defaultAnimation: 'view-slide-up'
            });
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
