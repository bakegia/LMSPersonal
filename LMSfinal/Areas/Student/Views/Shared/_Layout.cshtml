@using LMSfinal.Data
@using LMSfinal.Models.EF
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS Student</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/student-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/lms-shared.css" asp-append-version="true" />
</head>
@{
            var controller = ViewContext.RouteData.Values["controller"]?.ToString();
        var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<body>

    <div id="page-loader">
        <div class="spinner-border text-primary"></div>
    </div>

    <!-- Sidebar -->
    <aside class="sidebar-student">

        <div class="sidebar-header">

            <strong>STUDENT</strong>

            @if (User.Identity?.IsAuthenticated == true)
            {
                var user = await UserManager.GetUserAsync(User);

                var avatarUrl = "~/images/avatars/default-avatar.png";

                if (user?.Avatar != null)
                    avatarUrl = user.Avatar;

                <div class="avatar-box">

                    <img src="@avatarUrl"
                         class="rounded-circle" />

                    <div class="user-name">
                        @User.Identity.Name
                    </div>

                </div>
            }

        </div>

        <nav class="sidebar-nav">

            <a asp-area="Student"
               asp-controller="HomeStudent"
               asp-action="Index"
               class="sidebar-link @(controller == "HomeStudent" ? "active" : "")">
                <i class="fa-solid fa-house"></i>
                Dashboard
            </a>

            <a asp-area="Student"
               asp-controller="CourseStudent"
               asp-action="Index"
               class="sidebar-link @(controller == "CourseStudent" ? "active" : "")">
                <i class="fa-solid fa-book"></i>
                Khóa học
            </a>

            <a asp-area="Student"
               asp-controller="Schedule"
               asp-action="MySchedule"
               class="sidebar-link @(controller == "Schedule" ? "active" : "")">
                <i class="fa-solid fa-calendar-days"></i>
                Lịch học
            </a>

            <a asp-area="Student"
               asp-controller="Assignment"
               asp-action="Index"
               class="sidebar-link @(controller == "Assignment" ? "active" : "")">
                <i class="fa-solid fa-file-lines"></i>
                Bài tập
            </a>

            <a asp-area="Student"
               asp-controller="Notification"
               asp-action="Index"
               class="sidebar-link @(controller == "Notification" ? "active" : "")">
                <i class="fa-solid fa-bell"></i>
                Thông báo
            </a>

            <a asp-area="Student"
               asp-controller="Attendance"
               asp-action="MyAttendanceHistory"
               class="sidebar-link @(controller == "Attendance" ? "active" : "")">
                <i class="fa-solid fa-calendar-check"></i>
                Điểm danh
            </a>

            <a asp-area="Student"
               asp-controller="Grade"
               asp-action="Index"
               class="sidebar-link @(controller == "Grade" ? "active" : "")">
                <i class="fa-solid fa-chart-line"></i>
                Điểm số
            </a>

            <a asp-area=""
               asp-controller="Register"
               asp-action="AvailableClassroomsForStudent"
               class="sidebar-link @(controller == "Register" ? "active" : "")">
                <i class="fa-solid fa-clipboard-list"></i>
                Đăng ký lớp
            </a>

            <a asp-area="Student"
               asp-controller="Payment"
               asp-action="Index"
               class="sidebar-link @(controller == "Payment" ? "active" : "")">
                <i class="fa-solid fa-credit-card"></i>
                Thanh toán
            </a>
            <a asp-area="Student"
               asp-controller="Tuition"
               asp-action="Index"
               class="sidebar-link @(controller == "Tuition" ? "active" : "")">
                <i class="fa-solid fa-credit-card"></i>
                Thanh toán
            </a>

            <hr />

            <a asp-area="Student"
               asp-controller="Profile"
               asp-action="Index"
               class="sidebar-link @(controller == "Profile" ? "active" : "")">
                <i class="fa-solid fa-user"></i>
                Hồ sơ
            </a>

            <a asp-area="Admin"
               asp-controller="Account"
               asp-action="Logout"
               class="sidebar-link text-danger">
                <i class="fa-solid fa-right-from-bracket"></i>
                Đăng xuất
            </a>

        </nav>

    </aside>

    <!-- Content -->
    <div class="main-wrapper">

        <header class="main-header">

            <h5 class="page-title">
                @ViewData["Title"]
            </h5>

            <div class="user-info">

                @{
                    var topAvatar = "~/images/avatars/default-avatar.png";
                    var topUser = await UserManager.GetUserAsync(User);

                    if (topUser?.Avatar != null)
                        topAvatar = topUser.Avatar;
                }

                <img src="@topAvatar"
                     class="rounded-circle header-avatar" />

                <span>
                    Xin chào, @User.Identity?.Name
                </span>

            </div>

        </header>

        <main class="main-content">
            @RenderBody()
        </main>

    </div>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const sidebar = document.querySelector(".sidebar-student");

            if (!sidebar) return;

            // Khôi phục vị trí scroll
            const savedPosition = sessionStorage.getItem("sidebarScroll");

            if (savedPosition) {
                sidebar.scrollTop = parseInt(savedPosition);
            }

            // Lưu vị trí scroll
            sidebar.addEventListener("scroll", function () {
                sessionStorage.setItem(
                    "sidebarScroll",
                    sidebar.scrollTop
                );
            });

        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
