@model IEnumerable<LMSfinal.Models.EF.Attendance>
@{
    ViewData["Title"] = "Lịch sử điểm danh của tôi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml"; // Hoặc layout dành cho Student
}

<div class="container-fluid mt-4">
    <h3 class="mb-4"><i class="fa-solid fa-user-check"></i> Nhật ký chuyên cần</h3>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow-sm">
                <div class="card-body text-center">
                    <h6>Tổng số buổi đã học</h6>
                    <h2 class="fw-bold">@ViewBag.TotalSessions</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body text-center">
                    <h6>Số buổi hiện diện</h6>
                    <h2 class="fw-bold">@ViewBag.PresentCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white shadow-sm">
                <div class="card-body text-center">
                    <h6>Số buổi vắng</h6>
                    <h2 class="fw-bold">@ViewBag.AbsentCount</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body bg-light">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Chọn môn học/lớp học để xem chi tiết:</label>
                    <select name="classroomId" class="form-select border-primary" onchange="this.form.submit()">
                        <option value="">-- Tất cả các môn học --</option>
                        @foreach (var c in (List<LMSfinal.Models.EF.Classroom>)ViewBag.Classrooms)
                        {
                            <option value="@c.Id" selected="@(ViewBag.SelectedClassroom == c.Id ? "selected" : null)">
                                @c.NameClass (@c.ClassCode)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <a asp-action="MyAttendanceHistory" class="btn btn-outline-secondary w-100">Xóa lọc</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Ngày điểm danh</th>
                        <th>Lớp học</th>
                        <th class="text-center">Trạng thái</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@item.AttendanceDate.ToString("dd/MM/yyyy")</div>
                                    <small class="text-muted">@item.AttendanceDate.DayOfWeek</small>
                                </td>
                                <td>
                                    <div class="fw-bold">@item.Classroom.NameClass</div>
                                    <small class="text-muted">Mã: @item.Classroom.ClassCode</small>
                                </td>
                                <td class="text-center">
                                    @if (item.IsPresent)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success px-3 py-2">
                                            <i class="fa-solid fa-check-circle me-1"></i> Có mặt
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger px-3 py-2">
                                            <i class="fa-solid fa-times-circle me-1"></i> Vắng mặt
                                        </span>
                                    }
                                </td>
                                <td>
                                    <small class="text-muted italic">@(item.IsPresent ? "" : "Vắng không lý do")</small>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <p>Bạn chưa có dữ liệu điểm danh nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>