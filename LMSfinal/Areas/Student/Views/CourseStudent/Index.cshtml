@model IEnumerable<LMSfinal.Models.EF.Classroom>
@{
    ViewData["Title"] = "Danh sách môn học";
    Layout = "~/Areas/Student/Views/Shared/_Layout.cshtml";
    // Lấy danh sách bài đã xong từ ViewBag
    var completedIds = ViewBag.CompletedLessonIds as List<int> ?? new List<int>();
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase">My Course</h2>
        <div class="mx-auto bg-primary" style="height: 3px; width: 60px;"></div>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                // LOGIC TÍNH PROGRESS
                var allLessonsInClass = item.Sections.SelectMany(s => s.Lessons).ToList();
                int totalLessons = allLessonsInClass.Count;
                int completedCount = allLessonsInClass.Count(l => completedIds.Contains(l.Id));
                int percent = totalLessons > 0 ? (int)((double)completedCount / totalLessons * 100) : 0;

                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm overflow-hidden card-hover">
                        <div class="position-relative">
                            <img src="@(item.Course != null && !string.IsNullOrEmpty(item.Course.ImageUrl)
                                                                          ? item.Course.ImageUrl
                                                                          : "/images/courses/default-course.png")"
                         class="card-img-top"
                         alt="@item.Course?.Title"
                         style="height: 200px; object-fit: cover;">

                            <span class="position-absolute top-0 end-0 m-2 badge bg-dark opacity-75">
                                MÔN HỌC
                            </span>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark mb-2">@item.NameClass</h5>
                            <p class="text-muted small mb-3">
                                <i class="fa-solid fa-book-open me-1"></i>
                                Khóa học: @(item.Course?.Title ?? "Chưa cập nhật")
                            </p>

                            <div class="mt-auto mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="small fw-bold text-secondary">
                                        <i class="fa-solid fa-chart-line me-1"></i> @percent% hoàn thành
                                    </span>
                                    <span class="small text-muted">@completedCount/@totalLessons bài</span>
                                </div>
                                <div class="progress" style="height: 6px; background-color: #eee;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width: @percent%; background: linear-gradient(90deg, #007bff, #00d4ff);"
                                         aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100">
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <a asp-area="Student" asp-controller="CourseStudent" asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-primary px-4 rounded-pill w-100">
                                    Vào học ngay
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">Không tìm thấy môn học nào phù hợp.</p>
            </div>
        }
    </div>
</div>

<style>
    .card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .card-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.12) !important;
        }

    /* Hiệu ứng bo góc cho progress bar */
    .progress {
        border-radius: 10px;
        overflow: hidden;
    }

    .progress-bar {
        transition: width 0.8s ease-in-out;
    }
</style>