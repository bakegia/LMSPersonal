@model LMSfinal.Models.ViewModels.Student.StudentTuitionIndexVM
@{
    ViewData["Title"] = "Học phí của tôi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold">
                <i class="fa-solid fa-wallet text-primary me-2"></i>Học Phí Của Tôi
            </h2>
            <p class="text-muted">Tổng hợp học phí theo niên học kỳ</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Lọc theo niên học kỳ</label>
                    <select name="semester" class="form-select" onchange="this.form.submit()">
                        <option value="">Tất cả</option>
                        @foreach (var s in Model.SemesterOptions)
                        {
                            <option value="@s" selected="@(Model.SelectedSemester == s ? "selected" : null)">
                                @s
                            </option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="text-muted">Phải Thu</div>
                    <h4 class="fw-bold text-primary">@Model.TotalPayable.ToString("N0") VND</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="text-muted">Đã Thu</div>
                    <h4 class="fw-bold text-success">@Model.TotalPaid.ToString("N0") VND</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="text-muted">Còn Nợ</div>
                    <h4 class="fw-bold text-danger">@Model.TotalBalance.ToString("N0") VND</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light border-bottom">
            <h5 class="mb-0 fw-bold">
                <i class="fa-solid fa-table me-2"></i>Chi tiết theo kỳ
            </h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Niên Học Kỳ</th>
                        <th class="text-end">Học Phí Chưa Giảm</th>
                        <th class="text-end">Miễn Giảm</th>
                        <th class="text-end">Phải Thu</th>
                        <th class="text-end">Đã Thu</th>
                        <th class="text-end">Còn Nợ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="fw-bold">@item.SemesterLabel</td>
                                <td class="text-end">@item.BaseTuition.ToString("N0") VND</td>
                                <td class="text-end">@item.Discount.ToString("N0") VND</td>
                                <td class="text-end text-primary fw-bold">@item.Payable.ToString("N0") VND</td>
                                <td class="text-end text-success fw-bold">@item.Paid.ToString("N0") VND</td>
                                <td class="text-end text-danger fw-bold">@item.Balance.ToString("N0") VND</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Chưa có dữ liệu học phí.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>