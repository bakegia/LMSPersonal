<button type="button"
        class="btn w-100 mt-3"
        style="background:#6D4C41; color:#FFF8E1; font-weight:600;"
        onclick="submitPayment()">
    ☕ Thanh toán
</button>
<script>
    function payVNPay(billId, amount) {

        const form = document.getElementById("vnpayForm");

        form.querySelector('[name="BillId"]').value = billId;
        form.querySelector('[name="Amount"]').value = amount;
        form.querySelector('[name="OrderDescription"]').value =
            "Thanh toán học phí #" + billId;

        form.submit();
    }

    function payMomo(billId, amount) {

        const form = document.getElementById("momoForm");

        form.querySelector('[name="BillId"]').value = billId;
        form.querySelector('[name="Amount"]').value = amount;
        form.querySelector('[name="OrderInfo"]').value =
            "Thanh toán học phí #" + billId;

        form.submit();
    }
</script>