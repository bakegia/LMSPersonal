@using LMSfinal.Models.Utilities
@using LMSfinal.Models.Enums
@model LMSfinal.Models.EF.ClassroomGrade
@{
    ViewData["Title"] = "Chi Tiết Điểm";
    Layout = "~/Areas/Student/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- Header -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white border-0">
                    <h4 class="mb-0 fw-bold">
                        <i class="fa-solid fa-book me-2"></i>@ViewBag.ClassroomName
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Môn Học</small>
                            <strong>@ViewBag.CourseName</strong>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Mã Lớp</small>
                            <strong>@ViewBag.ClassroomCode</strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Score Breakdown -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-success text-white border-0">
                    <h5 class="mb-0 fw-bold">
                        <i class="fa-solid fa-chart-bar me-2"></i>Chi Tiết Điểm
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <!-- Process Score -->
                        <div class="col-md-6">
                            <div class="score-box p-3 rounded border-start border-5 border-primary">
                                <small class="text-muted d-block mb-1">Điểm Quá Trình</small>
                                <h3 class="mb-1 text-primary">
                                    @(Model.ProcessScore?.ToString("F1") ?? "—")
                                    <small class="text-muted">/10</small>
                                </h3>
                                <small class="text-muted">Trọng số: 30%</small>
                            </div>
                        </div>

                        <!-- Midterm Score -->
                        <div class="col-md-6">
                            <div class="score-box p-3 rounded border-start border-5 border-info">
                                <small class="text-muted d-block mb-1">Điểm Giữa Kỳ</small>
                                <h3 class="mb-1 text-info">
                                    @(Model.MidtermScore?.ToString("F1") ?? "—")
                                    <small class="text-muted">/10</small>
                                </h3>
                                <small class="text-muted">Trọng số: 20%</small>
                            </div>
                        </div>

                        <!-- Final Exam Score -->
                        <div class="col-md-6">
                            <div class="score-box p-3 rounded border-start border-5 border-warning">
                                <small class="text-muted d-block mb-1">Điểm Thi</small>
                                <h3 class="mb-1 text-warning">
                                    @(Model.FinalExamScore?.ToString("F1") ?? "—")
                                    <small class="text-muted">/10</small>
                                </h3>
                                <small class="text-muted">Trọng số: 50%</small>
                            </div>
                        </div>

                        <!-- Final Score -->
                        <div class="col-md-6">
                            <div class="score-box p-3 rounded border-start border-5 border-success">
                                <small class="text-muted d-block mb-1">Điểm Tổng</small>
                                <h3 class="mb-1 text-success">
                                    @(Model.FinalScore.ToString("F2") ?? "—")
                                    <small class="text-muted">/10</small>
                                </h3>
                                <small class="text-muted">Công thức: (QT×30% + GK×20% + Thi×50%)</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Comments Section -->
            @if (!string.IsNullOrEmpty(Model.Comments))
            {
                <div class="card border-0 shadow-sm mb-4 border-start border-5 border-info">
                    <div class="card-header bg-info bg-opacity-10 border-0">
                        <h5 class="mb-0 fw-bold">
                            <i class="fa-solid fa-note-sticky me-2"></i>Ghi Chú Từ Giáo Viên
                        </h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-0">@Model.Comments</p>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Summary Card -->
            <div class="card border-0 shadow-sm sticky-top mb-4" style="top: 20px;">
                <div class="card-header bg-dark text-white border-0">
                    <h5 class="mb-0 fw-bold">
                        <i class="fa-solid fa-summary me-2"></i>Tóm Tắt
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Grade Badge -->
                    <div class="text-center mb-4 p-3 bg-light rounded">
                        <small class="text-muted d-block mb-2">Hạng Điểm</small>
                        @{
                            var gradeColor = Model.GradeLetterClass switch
                            {
                                GradeLetterEnum.A => "success",
                                GradeLetterEnum.B => "info",
                                GradeLetterEnum.C => "warning",
                                GradeLetterEnum.D => "danger",
                                _ => "secondary"
                            };
                        }
                        <h2 class="mb-0">
                            <span class="badge bg-@gradeColor" style="font-size: 1.5rem;">@Model.GradeLetterClass</span>
                        </h2>
                        <p class="mb-0 mt-2">
                            <strong>@ViewBag.GradeDescription</strong>
                        </p>
                        <small class="text-muted d-block mt-1">
                            Khoảng: @ViewBag.GradeRange
                        </small>
                    </div>

                    <!-- GPA -->
                    <div class="text-center mb-3 p-3 bg-light rounded">
                        <small class="text-muted d-block mb-1">GPA</small>
                        <h3 class="mb-0 text-primary">
                            @(Model.GPA.ToString("F2") ?? "—") <small class="text-muted">/4</small>
                        </h3>
                    </div>

                    <!-- Status -->
                    <div class="mb-3 p-3 bg-light rounded">
                        <small class="text-muted d-block mb-1">Trạng Thái</small>
                        @if (Model.FinalScore >= 4.0m)
                        {
                            <span class="badge bg-success w-100">
                                <i class="fa-solid fa-check-circle me-1"></i>Đạt
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger w-100">
                                <i class="fa-solid fa-times-circle me-1"></i>Không Đạt
                            </span>
                        }
                    </div>

                    <hr>

                    <!-- Update Info -->
                    <div class="small text-muted">
                        <p class="mb-2">
                            <i class="fa-solid fa-calendar me-1"></i>
                            <strong>Ngày ghi:</strong> @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                        </p>
                        @if (Model.UpdatedDate != null)
                        {
                            <p class="mb-0">
                                <i class="fa-solid fa-pen me-1"></i>
                                <strong>Cập nhật:</strong> @Model.UpdatedDate?.ToString("dd/MM/yyyy HH:mm")
                            </p>
                        }
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="card border-0 shadow-sm">
                <div class="card-body d-grid gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-arrow-left me-1"></i>Quay Lại
                    </a>
                    <a asp-action="Transcript" class="btn btn-outline-primary">
                        <i class="fa-solid fa-file-excel me-1"></i>Bảng Điểm Tổng
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- ... style giữ nguyên ... -->