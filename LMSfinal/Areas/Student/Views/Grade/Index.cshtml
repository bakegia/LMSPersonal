@using LMSfinal.Models.Enums
@using LMSfinal.Models.Utilities
@model LMSfinal.Models.ViewModels.StudentGradeIndexVM
@{
    ViewData["Title"] = "Xem Điểm Của Tôi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold">
                <i class="fa-solid fa-star text-warning me-2"></i>Điểm Của Tôi
            </h2>
            <p class="text-muted">Xem điểm các lớp học mà bạn đã tham gia</p>
        </div>
    </div>

    @if (Model != null && Model.Items.Count > 0)
    {
        <!-- Quick Stats -->
        <div class="row mb-4 g-3">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">Tổng Lớp</h6>
                        <h3 class="fw-bold text-primary">@Model.TotalCourses</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">Đã Ghi Điểm</h6>
                        <h3 class="fw-bold text-success">@Model.GradedCourses</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">Chưa Ghi Điểm</h6>
                        <h3 class="fw-bold text-danger">@Model.UngradedCourses</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">Điểm Trung Bình</h6>
                        <h3 class="fw-bold text-info">
                            @Model.AverageScore.ToString("F2")
                        </h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grades Table -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light border-bottom">
                <h5 class="mb-0 fw-bold">
                    <i class="fa-solid fa-table me-2"></i>Danh Sách Điểm
                </h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 5%">STT</th>
                            <th style="width: 20%">Tên Lớp</th>
                            <th style="width: 20%">Môn Học</th>
                            <th style="width: 12%">Mã Lớp</th>
                            <th style="width: 12%">Quá Trình</th>
                            <th style="width: 12%">Giữa Kỳ</th>
                            <th style="width: 12%">Thi</th>
                            <th style="width: 10%">Điểm Tổng</th>
                            <th style="width: 8%">Hạng</th>
                            <th style="width: 8%">GPA</th>
                            <th style="width: 10%">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int index = 1;
                        }
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="fw-bold">@index</td>
                                <td>
                                    <strong>@item.ClassroomName</strong>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">
                                        <i class="fa-solid fa-book me-1"></i>@item.CourseName
                                    </span>
                                </td>
                                <td>
                                    <small class="text-muted">@item.ClassroomCode</small>
                                </td>
                                <td>
                                    @if (item.Grade?.ProcessScore.HasValue == true)
                                    {
                                        <span class="badge bg-info">@item.Grade.ProcessScore.Value.ToString("F1")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">—</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Grade?.MidtermScore.HasValue == true)
                                    {
                                        <span class="badge bg-info">@item.Grade.MidtermScore.Value.ToString("F1")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">—</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Grade?.FinalExamScore.HasValue == true)
                                    {
                                        <span class="badge bg-info">@item.Grade.FinalExamScore.Value.ToString("F1")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">—</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Grade != null && item.Grade.FinalScore > 0)
                                    {
                                        <strong class="text-primary">@item.Grade.FinalScore.ToString("F2")</strong>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Grade != null)
                                    {
                                        var gradeColor = item.Grade.GradeLetterClass switch
                                        {
                                            GradeLetterEnum.A => "success",
                                            GradeLetterEnum.B => "info",
                                            GradeLetterEnum.C => "warning",
                                            GradeLetterEnum.D => "danger",
                                            _ => "secondary"
                                        };
                                        <span class="badge bg-@gradeColor fw-bold">
                                            <i class="fa-solid fa-medal me-1"></i>@item.Grade.GradeLetterClass
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">—</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Grade?.GPA > 0)
                                    {
                                        <span class="badge bg-primary">@item.Grade.GPA.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Grade != null)
                                    {
                                        <a asp-action="Detail" asp-route-classroomId="@item.ClassroomId"
                                           class="btn btn-sm btn-primary" title="Xem chi tiết">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-secondary" disabled title="Chờ ghi điểm">
                                            <i class="fa-solid fa-hourglass"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                            index++;
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- View Transcript Button -->
        <div class="mt-4 text-center">
            <a asp-action="Transcript" class="btn btn-outline-primary btn-lg">
                <i class="fa-solid fa-file-excel me-2"></i>Xem Bảng Điểm Tổng Hợp
            </a>
        </div>
    }
    else
    {
        <!-- No Classrooms -->
        <div class="alert alert-info text-center py-5" role="alert">
            <i class="fa-solid fa-inbox fa-3x mb-3 text-info d-block"></i>
            <h5>Bạn chưa tham gia lớp nào</h5>
            <p class="text-muted">Vui lòng liên hệ quản trị viên để được ghi danh vào các lớp học</p>
        </div>
    }
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }

    .badge {
        font-weight: 500;
    }

    .btn-sm {
        padding: 0.5rem 0.75rem;
    }
</style>