@using LMSfinal.Models.EF
@model IEnumerable<ClassSchedule>
@{
    ViewData["Title"] = "Lịch học của tôi";
    // Thay đổi Layout tùy theo khu vực của học sinh (ví dụ Student hoặc User)
    Layout = "~/Areas/Student/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fa-solid fa-calendar-days"></i> Lịch học của tôi</h2>
        @* Chuyển hướng đến action WeeklyGrid của học sinh *@
        <a asp-action="WeeklyGrid" class="btn btn-primary">
            <i class="fa-solid fa-table-cells"></i> Xem thời khóa biểu (Lưới)
        </a>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            @* Form gửi đến action MySchedule *@
            <form method="get" asp-action="MySchedule" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Lọc theo lớp học</label>
                    <select name="classroomId" class="form-select">
                        <option value="">-- Tất cả các lớp --</option>
                        @if (ViewBag.Classrooms != null)
                        {
                            foreach (var c in (IEnumerable<Classroom>)ViewBag.Classrooms)
                            {
                                <option value="@c.Id">@c.NameClass (@c.ClassCode)</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Lọc theo thứ</label>
                    <select name="dayOfWeek" class="form-select">
                        <option value="">-- Tất cả các ngày --</option>
                        <option value="Monday">Thứ Hai</option>
                        <option value="Tuesday">Thứ Ba</option>
                        <option value="Wednesday">Thứ Tư</option>
                        <option value="Thursday">Thứ Năm</option>
                        <option value="Friday">Thứ Sáu</option>
                        <option value="Saturday">Thứ Bảy</option>
                        <option value="Sunday">Chủ Nhật</option>
                    </select>
                </div>
                <div class="col-md-5">
                    <button type="submit" class="btn btn-dark">
                        <i class="fa-solid fa-filter"></i> Lọc dữ liệu
                    </button>
                    <a asp-action="MySchedule" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-rotate-left"></i> Làm mới
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-primary text-white">
                <tr>
                    <th class="text-center" style="width: 120px;">Thứ</th>
                    <th>Môn học & Lớp</th>
                    <th>Giảng viên</th>
                    <th class="text-center">Ca học</th>
                    <th class="text-center">Thời gian</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center fw-bold text-primary">
                                @GetVietnameseDay(item.DayOfWeek)
                            </td>
                            <td>
                                <span class="fw-bold">@item.Classroom.Course?.Title</span><br />
                                <small class="badge bg-secondary">Lớp: @item.Classroom.NameClass (@item.Classroom.ClassCode)</small>
                            </td>
                            <td>
                                @if (item.Classroom.Instructor != null)
                                {
                                    <span><i class="fa-solid fa-user-tie me-1"></i> @item.Classroom.Instructor.FullName</span>
                                }
                                else
                                {
                                    <span class="text-muted italic">Đang cập nhật</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge bg-info text-dark">@item.TimeSlot.Name</span>
                            </td>
                            <td class="text-center">
                                <i class="fa-regular fa-clock me-1"></i>
                                @item.TimeSlot.StartTime.ToString(@"hh\:mm") - @item.TimeSlot.EndTime.ToString(@"hh\:mm")
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <img src="/images/empty-calendar.png" style="width: 50px; opacity: 0.5;" /><br />
                            Bạn không có lịch học nào trong danh sách này.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetVietnameseDay(DayOfWeek day)
    {
        return day switch
        {
            DayOfWeek.Monday => "Thứ Hai",
            DayOfWeek.Tuesday => "Thứ Ba",
            DayOfWeek.Wednesday => "Thứ Tư",
            DayOfWeek.Thursday => "Thứ Năm",
            DayOfWeek.Friday => "Thứ Sáu",
            DayOfWeek.Saturday => "Thứ Bảy",
            DayOfWeek.Sunday => "Chủ Nhật",
            _ => day.ToString()
        };
    }
}