@model IEnumerable<LMSfinal.Models.EF.FinalExamSchedule>
@{
    ViewData["Title"] = "Lịch Phân Công Coi Thi";
    Layout = "~/Areas/Instructor/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3 d-flex align-items-center">
            <h5 class="mb-0"><i class="bi bi-person-badge-fill me-2"></i>Lịch Phân Công Coi Thi Cuối Kỳ</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-info border-0 shadow-sm mb-4">
                <i class="bi bi-info-circle-fill me-2"></i>
                Chào giảng viên, đây là danh sách các ca thi mà bạn được <strong>Admin phân công</strong> làm giám thị coi thi.
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light text-secondary">
                            <tr>
                                <th style="width: 25%">Lớp & Môn Học</th>
                                <th style="width: 20%">Thời Gian Thi</th>
                                <th style="width: 15%">Địa Điểm</th>
                                <th style="width: 15%">Thời Lượng</th>
                                <th style="width: 25%">Ghi Chú Phân Công</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-dark">@item.Classroom?.Course?.Title</div>
                                        <div class="badge bg-secondary-subtle text-secondary border">@item.Classroom?.ClassCode</div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center mb-1">
                                            <i class="bi bi-calendar3 text-primary me-2"></i>
                                            <span>@item.ExamDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="d-flex align-items-center small fw-bold">
                                            <i class="bi bi-clock text-primary me-2"></i>
                                            <span>@item.StartTime.ToString(@"hh\:mm")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info-subtle text-info-emphasis border border-info">
                                            <i class="bi bi-geo-alt-fill me-1"></i>@item.RoomName
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-dark">@item.DurationInMinutes phút</span>
                                    </td>
                                    <td>
                                        <p class="small text-muted mb-0 italic">
                                            <i class="bi bi-sticky me-1"></i>@(string.IsNullOrEmpty(item.Notes) ? "Không có ghi chú thêm" : item.Notes)
                                        </p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <div class="mb-3">
                        <i class="bi bi-calendar-x display-1 text-light"></i>
                    </div>
                    <h5 class="text-secondary">Hiện tại bạn chưa có lịch phân công coi thi nào.</h5>
                    <p class="text-muted small">Mọi phân công mới sẽ được Admin cập nhật tại đây.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .bg-primary {
        background: linear-gradient(45deg, #4e73df 0%, #224abe 100%) !important;
    }

    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .badge {
        font-weight: 500;
        padding: 0.5em 0.8em;
    }
</style>