@using LMSfinal.Models.EF
@model Quiz

@{
    ViewData["Title"] = "Chỉnh sửa Quiz";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="fas fa-edit"></i> Chỉnh sửa Quiz
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
                        <!-- Bài học (chỉ hiển thị) -->
                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-book"></i> Bài học
                            </label>
                            <input type="text" class="form-control"
                                   value="@Model.Lesson?.Title" disabled />
                            <small class="text-muted">Không thể thay đổi bài học</small>
                        </div>

                        <!-- Tiêu đề -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">
                                <i class="fas fa-heading"></i> Tiêu đề
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Title" class="form-control" required />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <!-- Mô tả -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">
                                <i class="fas fa-align-left"></i> Mô tả
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <!-- Điểm qua -->
                        <div class="mb-3">
                            <label asp-for="PassingScore" class="form-label">
                                <i class="fas fa-percent"></i> Điểm qua (%)
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="PassingScore" type="number" class="form-control"
                                   min="0" max="100" required />
                            <small class="text-muted">Nhập giá trị từ 0 đến 100</small>
                            <span asp-validation-for="PassingScore" class="text-danger small"></span>
                        </div>

                        <!-- Thông tin thêm -->
                        <div class="alert alert-info">
                            <strong><i class="fas fa-info-circle"></i> Thông tin:</strong>
                            <ul class="mb-0 mt-2">
                                <li>Số câu hỏi: <strong>@Model.Questions.Count</strong></li>
                                <li>Ngày tạo: <strong>@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</strong></li>
                                <li>
                                    Trạng thái:
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Không hoạt động</span>
                                    }
                                </li>
                            </ul>
                        </div>

                        <!-- Nút hành động -->
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Cập nhật
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
