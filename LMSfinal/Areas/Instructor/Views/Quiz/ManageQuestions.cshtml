@using LMSfinal.Models.EF
@model Quiz

@{
    ViewData["Title"] = "Quiz Management";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">
                <i class="fa-solid fa-file-circle-question"></i>
                Quiz Management
            </h2>

            <p class="text-muted mb-0">
                Quiz:
                <span class="fw-semibold text-dark">@Model.Title</span>
            </p>
        </div>

        <button class="btn btn-primary rounded-pill shadow-sm px-4"
                data-bs-toggle="modal"
                data-bs-target="#addQuestionModal">
            <i class="fa-solid fa-plus"></i>
            Thêm câu hỏi
        </button>
    </div>

    <!-- SUCCESS MESSAGE -->
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4">
            <i class="fa-solid fa-circle-check"></i>
            @TempData["success"]
        </div>
    }

    <!-- QUESTIONS -->
    @if (Model.Questions.Any())
    {
        <div class="row">
            @{
                int questionIndex = 1;
            }

            @foreach (var question in Model.Questions.OrderBy(q => q.Order))
            {
                <div class="col-lg-6 mb-4">

                    <div class="card border-0 shadow-sm rounded-4 h-100 question-card">

                        <!-- HEADER -->
                        <div class="card-header bg-white border-0 pt-4 pb-2 px-4">

                            <div class="d-flex justify-content-between align-items-start">

                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <span class="question-number">
                                            @questionIndex
                                        </span>

                                        <h5 class="mb-0 fw-bold text-dark">
                                            Câu hỏi
                                        </h5>
                                    </div>

                                    <p class="text-secondary mb-0">
                                        @question.QuestionText
                                    </p>
                                </div>

                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
                                    <i class="fa-solid fa-star"></i>
                                    @question.Points điểm
                                </span>

                            </div>
                        </div>

                        <!-- BODY -->
                        <div class="card-body px-4">

                            <!-- ANSWERS -->
                            @if (question.Answers.Any())
                            {
                                <div class="mb-3">

                                    <div class="fw-semibold text-dark mb-3">
                                        <i class="fa-solid fa-list-check text-primary"></i>
                                        Danh sách đáp án
                                    </div>

                                    @foreach (var answer in question.Answers.OrderBy(a => a.Order))
                                    {
                                        <div class="answer-item mb-2">

                                            <div class="d-flex justify-content-between align-items-center">

                                                <div>

                                                    <span class="answer-label">
                                                        @answer.AnswerLabel
                                                    </span>

                                                    <span class="text-dark">
                                                        @answer.AnswerText
                                                    </span>

                                                    @if (answer.IsCorrect)
                                                    {
                                                        <span class="badge bg-success rounded-pill ms-2">
                                                            <i class="fa-solid fa-check"></i>
                                                            Correct
                                                        </span>
                                                    }

                                                </div>

                                                <div class="d-flex gap-2">

                                                    <button type="button"
                                                            class="btn btn-sm btn-light border rounded-circle action-btn"
                                                            onclick="editAnswer(@answer.Id)">
                                                        <i class="fa-solid fa-pen text-warning"></i>
                                                    </button>

                                                    <button type="button"
                                                            class="btn btn-sm btn-light border rounded-circle action-btn"
                                                            onclick="confirmDeleteAnswer(@answer.Id)">
                                                        <i class="fa-solid fa-trash text-danger"></i>
                                                    </button>

                                                </div>

                                            </div>

                                        </div>
                                    }

                                </div>
                            }
                            else
                            {
                                <div class="empty-answer-box">
                                    <i class="fa-solid fa-circle-exclamation"></i>
                                    Chưa có đáp án
                                </div>
                            }

                        </div>

                        <!-- FOOTER -->
                        <div class="card-footer bg-white border-0 px-4 pb-4">

                            <div class="d-flex flex-wrap gap-2">

                                <button type="button"
                                        class="btn btn-info rounded-pill text-white"
                                        data-bs-toggle="modal"
                                        data-bs-target="#addAnswerModal"
                                        onclick="setCurrentQuestionId(@question.Id)">
                                    <i class="fa-solid fa-plus"></i>
                                    Thêm đáp án
                                </button>

                                <button type="button"
                                        class="btn btn-warning rounded-pill text-dark"
                                        onclick="editQuestion(@question.Id)">
                                    <i class="fa-solid fa-pen"></i>
                                    Edit
                                </button>

                                <button type="button"
                                        class="btn btn-danger rounded-pill"
                                        onclick="confirmDeleteQuestion(@question.Id)">
                                    <i class="fa-solid fa-trash"></i>
                                    Delete
                                </button>

                            </div>

                        </div>

                    </div>

                </div>

                questionIndex++;
            }
        </div>
    }
    else
    {
        <!-- EMPTY -->
        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-body text-center py-5">

                <div class="mb-4">
                    <i class="fa-solid fa-file-circle-question empty-icon"></i>
                </div>

                <h4 class="fw-bold text-dark">
                    Chưa có câu hỏi nào
                </h4>

                <p class="text-muted mb-4">
                    Hãy tạo câu hỏi đầu tiên cho quiz này
                </p>

                <button class="btn btn-primary rounded-pill px-4"
                        data-bs-toggle="modal"
                        data-bs-target="#addQuestionModal">
                    <i class="fa-solid fa-plus"></i>
                    Thêm câu hỏi
                </button>

            </div>

        </div>
    }

    <!-- BACK -->
    <div class="mt-4">
        <a asp-action="Index"
           class="btn btn-dark rounded-pill px-4">
            <i class="fa-solid fa-arrow-left"></i>
            Quay lại
        </a>
    </div>

</div>

<!-- ========================= -->
<!-- MODAL ADD QUESTION -->
<!-- ========================= -->

<div class="modal fade" id="addQuestionModal" tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content border-0 rounded-4 shadow">

            <div class="modal-header bg-primary text-white border-0">

                <h5 class="modal-title fw-bold">
                    <i class="fa-solid fa-circle-plus"></i>
                    Thêm câu hỏi
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>

            </div>

            <form method="post" asp-area="Instructor" asp-controller="Quiz"
                  asp-action="AddQuestion"
                  asp-route-quizId="@Model.Id">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">

                    <div class="mb-3">

                        <label class="form-label fw-semibold">
                            Nội dung câu hỏi
                        </label>

                        <textarea name="QuestionText"
                                  class="form-control custom-input"
                                  rows="4"
                                  required></textarea>

                    </div>

                    <div>

                        <label class="form-label fw-semibold">
                            Số điểm
                        </label>

                        <input type="number"
                               name="Points"
                               class="form-control custom-input"
                               value="1"
                               min="1"
                               required />

                    </div>

                </div>

                <div class="modal-footer border-0">

                    <button type="button"
                            class="btn btn-light rounded-pill px-4"
                            data-bs-dismiss="modal">
                        Hủy
                    </button>

                    <button type="submit"
                            class="btn btn-primary rounded-pill px-4">
                        <i class="fa-solid fa-save"></i>
                        Lưu
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
@* ... (Giữ nguyên phần code cũ ở trên cho đến hết modal addQuestionModal) ... *@

<!-- ========================= -->
<!-- MODAL ADD ANSWER -->
<!-- ========================= -->
<div class="modal fade" id="addAnswerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header bg-info text-white border-0">
                <h5 class="modal-title fw-bold">
                    <i class="fa-solid fa-plus-circle"></i> Thêm đáp án
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="AddAnswer">
                @Html.AntiForgeryToken()
                <input type="hidden" name="questionId" id="questionIdInput" />
                <input type="hidden" name="quizId" value="@Model.Id" />

                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nhãn (A, B, C...)</label>
                        <input type="text" name="AnswerLabel" class="form-control custom-input" placeholder="Ví dụ: A" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nội dung đáp án</label>
                        <textarea name="AnswerText" class="form-control custom-input" rows="3" required></textarea>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsCorrect" value="true" id="isCorrectSwitch">
                        <label class="form-check-label fw-semibold" for="isCorrectSwitch">Đây là đáp án đúng</label>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-info text-white rounded-pill px-4">Lưu đáp án</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL DELETE CONFIRMATION (Dùng chung cho cả Q & A) -->
<!-- ========================= -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-body text-center p-4">
                <i class="fa-solid fa-circle-exclamation text-danger mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold">Xác nhận xóa?</h5>
                <p class="text-muted">Hành động này không thể hoàn tác.</p>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="quizId" value="@Model.Id" />
                    <div class="d-flex gap-2 justify-content-center mt-4">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger rounded-pill px-4">Xóa ngay</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<!-- MODAL EDIT QUESTION -->
<div class="modal fade" id="editQuestionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header bg-warning text-dark border-0">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-pen-to-square"></i> Sửa câu hỏi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="UpdateQuestion">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editQuestionId" />
                <input type="hidden" name="quizId" value="@Model.Id" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nội dung câu hỏi</label>
                        <textarea name="QuestionText" id="editQuestionText" class="form-control custom-input" rows="4" required></textarea>
                    </div>
                    <div>
                        <label class="form-label fw-semibold">Số điểm</label>
                        <input type="number" name="Points" id="editQuestionPoints" class="form-control custom-input" min="1" required />
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL EDIT ANSWER -->
<div class="modal fade" id="editAnswerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header bg-warning text-dark border-0">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-pen-to-square"></i> Sửa đáp án</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="UpdateAnswer">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editAnswerId" />
                <input type="hidden" name="quizId" value="@Model.Id" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nhãn (A, B, C...)</label>
                        <input type="text" name="AnswerLabel" id="editAnswerLabel" class="form-control custom-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nội dung đáp án</label>
                        <textarea name="AnswerText" id="editAnswerText" class="form-control custom-input" rows="3" required></textarea>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsCorrect" value="true" id="editIsCorrect">
                        <label class="form-check-label fw-semibold" for="editIsCorrect">Đây là đáp án đúng</label>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>
<style>

    body {
        background: #f5f7fb;
    }

    .question-card {
        transition: 0.25s ease;
    }

        .question-card:hover {
            transform: translateY(-3px);
        }

    .question-number {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        background: #0d6efd;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    .answer-item {
        background: #f8f9fc;
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #eef1f5;
    }

    .answer-label {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #0d6efd;
        color: white;
        font-weight: 600;
        margin-right: 8px;
    }

    .action-btn {
        width: 35px;
        height: 35px;
    }

    .custom-input {
        border-radius: 14px;
        border: 1px solid #dbe1ea;
        padding: 12px;
    }

        .custom-input:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.15rem rgba(13,110,253,.15);
        }

    .empty-answer-box {
        background: #fff8e1;
        border-radius: 12px;
        padding: 14px;
        color: #9a6700;
        text-align: center;
    }

    .empty-icon {
        font-size: 70px;
        color: #d0d5dd;
    }

</style>

@section Scripts {

    <script>

        let currentQuestionId = 0;

        function setCurrentQuestionId(questionId) {
            currentQuestionId = questionId;
            document.getElementById('questionIdInput').value = questionId;
        }

        function confirmDeleteQuestion(questionId) {
            const form = document.getElementById('deleteQuestionForm');
            form.action = `/Instructor/Quiz/DeleteQuestion/${questionId}`;

            const modal = new bootstrap.Modal(
                document.getElementById('deleteQuestionModal')
            );

            modal.show();
        }

        function confirmDeleteAnswer(answerId) {
            const form = document.getElementById('deleteAnswerForm');
            form.action = `/Instructor/Quiz/DeleteAnswer/${answerId}`;

            const modal = new bootstrap.Modal(
                document.getElementById('deleteAnswerModal')
            );

            modal.show();
        }

        function editQuestion(questionId) {
            alert('Chức năng edit question sẽ được cập nhật');
        }

        function editAnswer(answerId) {
            alert('Chức năng edit answer sẽ được cập nhật');
        }

    </script>
    <script>
        function setCurrentQuestionId(questionId) {
            document.getElementById('questionIdInput').value = questionId;
        }

        function confirmDeleteQuestion(questionId) {
            const form = document.getElementById('deleteForm');
            form.action = `/Instructor/Quiz/DeleteQuestion/${questionId}`;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

        function confirmDeleteAnswer(answerId) {
            const form = document.getElementById('deleteForm');
            form.action = `/Instructor/Quiz/DeleteAnswer/${answerId}`;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

                function editQuestion(questionId) {
            fetch(`/Instructor/Quiz/GetQuestion/${questionId}`)
                .then(response => response.json())
                .then(data => {
                    document.getElementById('editQuestionId').value = data.id;
                    document.getElementById('editQuestionText').value = data.text;
                    document.getElementById('editQuestionPoints').value = data.points;
                    new bootstrap.Modal(document.getElementById('editQuestionModal')).show();
                });
        }

        function editAnswer(answerId) {
            fetch(`/Instructor/Quiz/GetAnswer/${answerId}`)
                .then(response => response.json())
                .then(data => {
                    document.getElementById('editAnswerId').value = data.id;
                    document.getElementById('editAnswerLabel').value = data.label;
                    document.getElementById('editAnswerText').value = data.text;
                    document.getElementById('editIsCorrect').checked = data.isCorrect;
                    new bootstrap.Modal(document.getElementById('editAnswerModal')).show();
                });
        }
    </script>

}