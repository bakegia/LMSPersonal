@using LMSfinal.Models.EF
@model List<Quiz>

@{
    ViewData["Title"] = "Danh sách Quiz";
    Layout = "~/Areas/Instructor/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2>
                <i class="fa-solid fa-question-circle"></i> Danh sách Quiz
            </h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Tạo Quiz mới
            </a>
        </div>
    </div>

    <!-- Lọc theo Classroom -->
    <div class="row mb-3">
        <div class="col-md-4">
            <form method="get" asp-action="Index">
                <div class="input-group">
                    <select name="classroomId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Chọn lớp học --</option>
                        @if (ViewBag.Classrooms != null)
                        {
                            foreach (var classroom in ViewBag.Classrooms)
                            {
                                <option value="@classroom.Value" selected="@(ViewBag.SelectedClassroom?.ToString() == classroom.Value)">
                                    @classroom.Text
                                </option>
                            }
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    <!-- Thông báo thành công -->
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-check-circle"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Danh sách Quiz -->
    @if (Model.Any())
    {
        <div class="table-responsive shadow-sm">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 5%">STT</th>
                        <th style="width: 20%">Tên Quiz</th>
                        <th style="width: 15%">Bài học</th>
                        <th style="width: 15%">Lớp học</th>
                        <th style="width: 10%">Số câu</th>
                        <th style="width: 8%">Điểm qua</th>
                        <th style="width: 12%">Ngày tạo</th>
                        <th style="width: 10%">Trạng thái</th>
                        <th style="width: 5%">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                    }
                    @foreach (var quiz in Model)
                    {
                        <tr>
                            <td>@index</td>
                            <td>
                                <strong>@quiz.Title</strong>
                                @if (!string.IsNullOrEmpty(quiz.Description))
                                {
                                    <br />
                                    <small class="text-muted">@quiz.Description</small>
                                }
                            </td>
                            <td>@quiz.Lesson?.Title</td>
                            <td>@quiz.Lesson?.Section?.Classroom?.NameClass</td>
                            <td>
                                <span class="badge bg-info">@quiz.Questions.Count</span>
                            </td>
                            <td>@quiz.PassingScore%</td>
                            <td>
                                <small>@quiz.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small>
                            </td>
                            <td>
                                @if (quiz.IsActive)
                                {
                                    <span class="badge bg-success">
                                        <i class="fa-solid fa-check"></i> Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        <i class="fa-solid fa-times"></i> Không hoạt động
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="ManageQuestions" asp-route-quizId="@quiz.Id" 
                                       class="btn btn-info" title="Quản lý câu hỏi">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@quiz.Id" 
                                       class="btn btn-warning" title="Chỉnh sửa">
                                        <i class="fa-solid fa-edit"></i>
                                    </a>
                                    <a asp-action="Results" asp-route-quizId="@quiz.Id" 
                                       class="btn btn-success" title="Xem kết quả">
                                        <i class="fa-solid fa-chart-bar"></i>
                                    </a>
                                    <button type="button" class="btn btn-danger" 
                                            onclick="confirmDelete(@quiz.Id)" title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="fa-solid fa-circle-info fa-2x mb-3"></i>
            <p>Không có quiz nào</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Tạo Quiz mới
            </a>
        </div>
    }
</div>

<!-- Modal xác nhận xóa -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fa-solid fa-exclamation-triangle"></i> Xác nhận xóa
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa quiz này? Hành động này không thể hoàn tác.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="deleteForm" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-danger">
                        <i class="fa-solid fa-trash"></i> Xóa
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(quizId) {
            const form = document.getElementById('deleteForm');
            form.action = `/Instructor/Quiz/Delete/${quizId}`;
            const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }
    </script>
}