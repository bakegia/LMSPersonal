@model IEnumerable<LMSfinal.Models.EF.Classroom>
@{
    ViewData["Title"] = "Quản Lý Ghi Điểm";
    Layout = "~/Areas/Instructor/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold">
                        <i class="fa-solid fa-chart-column text-primary me-2"></i>Quản Lý Ghi Điểm
                    </h2>
                    <p class="text-muted">Chọn lớp học để bắt đầu ghi điểm cho học sinh</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-check-circle me-2"></i>@TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-exclamation-circle me-2"></i>@TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Classrooms Grid -->
    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var classroom in Model.OrderBy(c => c.NameClass))
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 transition-all hover-lift">
                        <!-- Card Header -->
                        <div class="card-header bg-gradient-primary text-white border-0 rounded-top">
                            <h5 class="card-title mb-0 fw-bold">
                                <i class="fa-solid fa-chalkboard me-2"></i>@classroom.NameClass
                            </h5>
                        </div>

                        <!-- Card Body -->
                        <div class="card-body">
                            <!-- Course Info -->
                            <div class="mb-3">
                                <small class="text-muted d-block mb-1">
                                    <i class="fa-solid fa-book me-1"></i><strong>Môn học:</strong>
                                </small>
                                <p class="mb-2 fw-semibold">@classroom.Course?.Title</p>
                            </div>

                            <!-- Class Code -->
                            <div class="mb-3">
                                <small class="text-muted d-block mb-1">
                                    <i class="fa-solid fa-hashtag me-1"></i><strong>Mã lớp:</strong>
                                </small>
                                <p class="mb-2 small">@classroom.ClassCode</p>
                            </div>

                            <!-- Student Count -->
                            <div class="mb-3 p-2 bg-light rounded">
                                <small class="text-muted d-block">
                                    <i class="fa-solid fa-users me-1"></i>Số học sinh:
                                </small>
                                <h6 class="mb-0">@classroom.ClassroomStudents.Count <span class="text-muted small">học sinh</span></h6>
                            </div>

                            <!-- Dates -->
                            <div class="small text-muted mb-3">
                                <i class="fa-solid fa-calendar me-1"></i>
                                @classroom.StartDate.ToString("dd/MM/yyyy") - @classroom.EndDate.ToString("dd/MM/yyyy")
                            </div>

                            <!-- Status Badge -->
                            <div class="mb-3">
                                @if (classroom.IsActive)
                                {
                                    <span class="badge bg-success">
                                        <i class="fa-solid fa-circle me-1"></i>Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        <i class="fa-solid fa-circle-pause me-1"></i>Không hoạt động
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Card Footer -->
                        <div class="card-footer bg-light border-top-0 rounded-bottom d-grid gap-2">
                            <a asp-action="GradeList" asp-route-classroomId="@classroom.Id"
                               class="btn btn-primary btn-sm">
                                <i class="fa-solid fa-pen-to-square me-1"></i>Ghi Điểm
                            </a>
                            <a asp-action="ExportToExcel" asp-route-classroomId="@classroom.Id"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="fa-solid fa-download me-1"></i>Xuất Excel
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5" role="alert">
            <i class="fa-solid fa-inbox fa-3x mb-3 text-info"></i>
            <h5>Bạn hiện không có lớp nào</h5>
            <p class="text-muted">Vui lòng liên hệ quản trị viên để được giao lớp học</p>
        </div>
    }
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #0d6efd 0%, #0854ca 100%);
    }

    .transition-all {
        transition: all 0.3s ease-in-out;
    }

    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.15) !important;
    }

    .card-header {
        background-color: #0d6efd;
    }
</style>