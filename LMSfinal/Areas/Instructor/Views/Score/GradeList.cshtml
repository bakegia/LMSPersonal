@using LMSfinal.Models.Enums
@using LMSfinal.Models.Utilities
@model LMSfinal.Models.ViewModels.ClassroomGradeListViewModel
@{
    ViewData["Title"] = "Danh Sách Ghi Điểm";
    Layout = "~/Areas/Instructor/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="fw-bold">
                        <i class="fa-solid fa-list text-primary me-2"></i>Ghi Điểm - @Model.ClassroomName
                    </h2>
                    <div class="breadcrumb-custom mt-2">
                        <small class="text-muted">
                            <i class="fa-solid fa-book me-1"></i>@Model.CourseName |
                            <i class="fa-solid fa-hashtag me-1"></i>@Model.ClassroomCode |
                            <i class="fa-solid fa-users me-1"></i>@Model.StudentGrades.Count học sinh
                        </small>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-arrow-left me-1"></i>Quay Lại
                    </a>
                    <a asp-action="ExportToExcel" asp-route-classroomId="@Model.ClassroomId" class="btn btn-outline-success">
                        <i class="fa-solid fa-download me-1"></i>Xuất Excel
                    </a>
                    <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#sendAllModal">
                        <i class="fa-solid fa-bell me-1"></i>Gửi Tất Cả
                    </button>
                    <button class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#sendSelectedModal">
                        <i class="fa-solid fa-bell me-1"></i>Gửi Đã Chọn
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-check-circle me-2"></i>@TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-xmark me-2"></i>@TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-1">Tổng Học Sinh</h6>
                    <h3 class="fw-bold text-primary">@Model.StudentGrades.Count</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-1">Đã Ghi Điểm</h6>
                    <h3 class="fw-bold text-success">@Model.StudentGrades.Count(s => s.GradeId > 0)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-1">Chưa Ghi Điểm</h6>
                    <h3 class="fw-bold text-danger">@Model.StudentGrades.Count(s => s.GradeId == 0)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-1">Điểm Trung Bình</h6>
                    <h3 class="fw-bold text-info">
                        @{
                            var avgScore = Model.StudentGrades.Where(s => s.GradeId > 0).Any()
                            ? Model.StudentGrades.Where(s => s.GradeId > 0).Average(s => s.FinalScore).ToString("F2")
                            : "N/A";
                        }
                        @avgScore
                    </h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Grades Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light border-bottom">
            <h5 class="mb-0 fw-bold">
                <i class="fa-solid fa-table me-2"></i>Danh Sách Học Sinh
            </h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 4%">
                            <input type="checkbox" class="form-check-input" onclick="toggleSelectAll(this)">
                        </th>
                        <th style="width: 5%">STT</th>
                        <th style="width: 20%">Tên Học Sinh</th>
                        <th style="width: 15%">Email</th>
                        <th style="width: 10%">Quá Trình</th>
                        <th style="width: 10%">Giữa Kỳ</th>
                        <th style="width: 10%">Thi</th>
                        <th style="width: 10%">Điểm Tổng</th>
                        <th style="width: 8%">Hạng</th>
                        <th style="width: 8%">GPA</th>
                        <th style="width: 20%">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.StudentGrades.Any())
                    {
                        int index = 1;
                        @foreach (var student in Model.StudentGrades)
                        {
                            var gradeColor = student.GradeLetterClass switch
                            {
                                GradeLetterEnum.A => "success",
                                GradeLetterEnum.B => "info",
                                GradeLetterEnum.C => "warning",
                                GradeLetterEnum.D => "danger",
                                _ => "secondary"
                            };
                            <tr>
                                <td>
                                    <input type="checkbox" class="form-check-input" name="selectedStudentIds" value="@student.StudentId">
                                </td>
                                <td class="fw-bold">@index</td>
                                <td>
                                    <strong>@student.StudentName</strong>
                                </td>
                                <td>
                                    <small class="text-muted">@student.StudentEmail</small>
                                </td>
                                <td>
                                    @if (student.ProcessScore.HasValue)
                                    {
                                        <span class="badge bg-info">@student.ProcessScore.Value.ToString("F1")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Chưa</span>
                                    }
                                </td>
                                <td>
                                    @if (student.MidtermScore.HasValue)
                                    {
                                        <span class="badge bg-info">@student.MidtermScore.Value.ToString("F1")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Chưa</span>
                                    }
                                </td>
                                <td>
                                    @if (student.FinalExamScore.HasValue)
                                    {
                                        <span class="badge bg-info">@student.FinalExamScore.Value.ToString("F1")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Chưa</span>
                                    }
                                </td>
                                <td>
                                    @if (student.GradeId > 0 && student.FinalScore > 0)
                                    {
                                        <strong class="text-primary">@student.FinalScore.ToString("F2")</strong>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (student.GradeId > 0)
                                    {
                                        <span class="badge bg-@gradeColor fw-bold">@student.GradeLetterClass</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">-</span>
                                    }
                                </td>
                                <td>
                                    @if (student.GradeId > 0 && student.GPA > 0)
                                    {
                                        <span class="badge bg-primary">@student.GPA.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="GradeInput"
                                           asp-route-classroomId="@Model.ClassroomId"
                                           asp-route-studentId="@student.StudentId"
                                           class="btn btn-primary" title="Ghi Điểm">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        @if (student.GradeId > 0)
                                        {
                                            <a asp-action="GradeDetail"
                                               asp-route-classroomId="@Model.ClassroomId"
                                               asp-route-studentId="@student.StudentId"
                                               class="btn btn-info" title="Xem Chi Tiết">
                                                <i class="fa-solid fa-eye"></i>
                                            </a>
                                        }
                                    </div>

                                    <form asp-action="SendGradeNotification"
                                          method="post"
                                          class="d-flex align-items-center gap-2 mt-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="classroomId" value="@Model.ClassroomId" />
                                        <input type="hidden" name="studentId" value="@student.StudentId" />
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="sendEmail" value="true" checked />
                                            <label class="form-check-label small">Mail</label>
                                        </div>
                                        <button type="submit" class="btn btn-sm btn-warning" title="Gửi thông báo">
                                            <i class="fa-solid fa-bell"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" class="text-center py-4">
                                <i class="fa-solid fa-inbox fa-2x text-muted mb-2 d-block"></i>
                                <p class="text-muted mb-0">Không có học sinh trong lớp</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODAL SEND ALL -->
<div class="modal fade" id="sendAllModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SendAllGradeNotifications" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="classroomId" value="@Model.ClassroomId" />
                <div class="modal-header">
                    <h5 class="modal-title">Gửi thông báo tất cả</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Bạn có chắc muốn gửi thông báo điểm cho toàn bộ học sinh?</p>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="sendEmail" value="true" checked />
                        <label class="form-check-label">Gửi kèm email</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Gửi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL SEND SELECTED -->
<div class="modal fade" id="sendSelectedModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="sendSelectedForm" asp-action="SendSelectedGradeNotifications" method="post" onsubmit="return prepareSelectedForm();">
                @Html.AntiForgeryToken()
                <input type="hidden" name="classroomId" value="@Model.ClassroomId" />
                <div id="selectedStudentIdsContainer"></div>
                <div class="modal-header">
                    <h5 class="modal-title">Gửi thông báo đã chọn</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Gửi thông báo điểm cho các học sinh đã chọn?</p>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="sendEmail" value="true" checked />
                        <label class="form-check-label">Gửi kèm email</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-warning">Gửi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleSelectAll(source) {
            const items = document.querySelectorAll('input[name="selectedStudentIds"]');
            items.forEach(i => i.checked = source.checked);
        }

        function prepareSelectedForm() {
            const container = document.getElementById('selectedStudentIdsContainer');
            container.innerHTML = '';

            const selected = Array.from(document.querySelectorAll('input[name="selectedStudentIds"]:checked'));
            if (selected.length === 0) {
                alert('Vui lòng chọn ít nhất một học sinh.');
                return false;
            }

            selected.forEach(cb => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'studentIds';
                input.value = cb.value;
                container.appendChild(input);
            });

            return true;
        }
    </script>
}