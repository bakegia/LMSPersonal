@using System.Globalization
@using System.Linq

@{
    ViewData["Title"] = "Lịch sử điểm danh";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";

    var items = Model as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    int totalSessions = items.Count();
    int totalPresent = items.Sum(x => (int)x.PresentCount);
    int totalCount = items.Sum(x => (int)x.TotalCount);
    int avgRate = totalCount > 0 ? (totalPresent * 100) / totalCount : 0;
}

<div class="container mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h3 class="mb-0"><i class="fa-solid fa-clock-rotate-left"></i> Lịch sử điểm danh lớp</h3>
        <a asp-action="Attendance" asp-route-id="@ViewBag.ClassroomId" class="btn btn-success">
            <i class="fa-solid fa-plus"></i> Điểm danh mới
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="text-muted small">Tổng số buổi</div>
                    <div class="fw-bold fs-4">@totalSessions</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="text-muted small">Tổng hiện diện</div>
                    <div class="fw-bold fs-4">@totalPresent</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="text-muted small">Tổng sĩ số</div>
                    <div class="fw-bold fs-4">@totalCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="text-muted small">Tỉ lệ trung bình</div>
                    <div class="fw-bold fs-4">@avgRate%</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4 border-0 shadow-sm bg-light">
        <div class="card-body">
            <form method="get" asp-action="AttendanceHistory" class="row g-3 align-items-end">
                <input type="hidden" name="id" value="@ViewBag.ClassroomId" />

                <div class="col-md-3">
                    <label class="form-label fw-bold">Từ ngày</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold">Đến ngày</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
                </div>

                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-magnifying-glass"></i> Tìm kiếm
                    </button>
                    <a asp-action="AttendanceHistory" asp-route-id="@ViewBag.ClassroomId" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-undo"></i> Làm mới
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-bordered align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="text-center">Ngày</th>
                    <th class="text-center">Sỉ số hiện diện</th>
                    <th style="width: 30%;">Tỉ lệ</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (items.Any())
                {
                    foreach (var item in items)
                    {
                        int percent = item.TotalCount > 0 ? (item.PresentCount * 100) / item.TotalCount : 0;
                        string barColor = percent >= 80 ? "bg-success" : (percent >= 50 ? "bg-warning" : "bg-danger");
                        string dayLabel = item.Date.ToString("dddd", new CultureInfo("vi-VN"));

                        <tr>
                            <td class="text-center fw-bold">
                                @item.Date.ToString("dd/MM/yyyy")
                                <div class="text-muted small">@dayLabel</div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-info text-dark">@item.PresentCount / @item.TotalCount</span>
                            </td>
                            <td>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar @barColor progress-bar-striped"
                                         role="progressbar"
                                         style="width: @percent%">
                                        @percent%
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <a asp-action="Attendance"
                                   asp-route-id="@ViewBag.ClassroomId"
                                   asp-route-date="@item.Date.ToString("yyyy-MM-dd")"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fa-solid fa-pen-to-square"></i> Chi tiết / Sửa
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            Không có dữ liệu lịch sử trong khoảng thời gian này.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>