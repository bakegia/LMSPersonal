@using LMSfinal.Models.EF
@model IEnumerable<Classroom>

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h2>My Classrooms</h2>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Mã Lớp</th>
            <th>Tên Môn Học</th>
            <th>Khóa Học</th>
            <th>Ngày Bắt Đầu</th>
            <th>Ngày Kết Thúc</th>
            <th>Sỉ Số</th>
            <th>Trạng Thái</th>
            <th width="250">Hành Động</th>
        </tr>
    </thead>
    <tbody>
        @{
            int index = 1;
        }

        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@index</td>
                    <td>@item.ClassCode</td>
                    <td>@item.NameClass</td>
                    <td>@item.Course?.Title</td>
                    <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.ClassroomStudents.Count / 30</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td>
                        <a asp-area="Instructor"
                           asp-controller="Section"
                           asp-action="Index"
                           asp-route-classroomId="@item.Id"
                           class="btn btn-sm btn-warning">
                            <i class="fa-solid fa-folder-plus"></i> Nội dung chương
                        </a>
                        <a asp-area="Instructor"
                           asp-controller="Classroom"
                           asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-primary">
                            Details
                        </a>

                        <a asp-area="Instructor"
                           asp-controller="Classroom"
                           asp-action="Students"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-info">
                            Students
                        </a>
                        <a asp-area="Instructor"
                           asp-controller="Classroom"
                           asp-action="Attendance"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-success">
                            <i class="fa-solid fa-check-to-slot"></i> Điểm danh
                        </a>
                        <a asp-controller="Classroom"
                           asp-action="AttendanceByDate"
                           asp-route-id="@item.Id">
                            Xem điểm danh
                        </a>
                    </td>
                    <td>
                        <!-- Thêm vào view Classroom Details của Instructor -->
                        <a asp-area="Instructor"
                           asp-controller="Quiz"
                           asp-action="Index"
                           class="btn btn-info">
                            <i class="fa-solid fa-file-lines"></i> Quản lý Quiz
                        </a>
                    </td>
                </tr>

                index++;
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">No classrooms found</td>
            </tr>
        }
    </tbody>
</table>