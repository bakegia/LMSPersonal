@using LMSfinal.Models.EF
@using static LMSfinal.Areas.Instructor.Controllers.ClassroomController
@model IEnumerable<AttendanceOverallViewModel>
@{
    ViewData["Title"] = "Tổng hợp lịch sử điểm danh";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="fa-solid fa-clipboard-list me-2"></i> Tất cả lịch sử điểm danh</h5>
        </div>

        <div class="card-body bg-light border-bottom">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase">Lọc theo lớp</label>
                    <select name="classroomId" class="form-select border-primary">
                        <option value="">-- Tất cả các lớp --</option>
                        @foreach (var c in (List<Classroom>)ViewBag.Classrooms)
                        {
                            <option value="@c.Id" selected="@(ViewBag.SelectedClassroom == c.Id ? "selected" : null)">
                                @c.NameClass (@c.ClassCode)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase">Từ ngày</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase">Đến ngày</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100 shadow-sm">
                        <i class="fa-solid fa-magnifying-glass me-1"></i> Tìm kiếm
                    </button>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th class="ps-4">Ngày dạy</th>
                        <th>Lớp học</th>
                        <th class="text-center">Sỉ số</th>
                        <th style="width: 25%;">Tỉ lệ</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var percent = item.TotalCount > 0 ? (item.PresentCount * 100) / item.TotalCount : 0;
                            string statusColor = percent >= 80 ? "success" : (percent >= 50 ? "warning" : "danger");

                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@item.Date.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted small">@item.Date.DayOfWeek</div>
                                </td>
                                <td>
                                    <div class="text-primary fw-bold">@item.ClassName</div>
                                    <div class="small text-muted">Mã lớp: @item.ClassCode</div>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-@statusColor">@item.PresentCount / @item.TotalCount</span>
                                </td>
                                <td>
                                    <div class="progress" style="height: 10px;">
                                        <div class="progress-bar bg-@statusColor" style="width: @percent%"></div>
                                    </div>
                                    <small class="fw-bold text-@statusColor">@percent% hiện diện</small>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Attendance" asp-controller="Classroom"
                                       asp-route-id="@item.ClassroomId"
                                       asp-route-date="@item.Date.ToString("yyyy-MM-dd")"
                                       class="btn btn-sm btn-outline-dark shadow-sm">
                                        <i class="fa-solid fa-edit"></i> Xem/Sửa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <p class="text-muted"><i class="fa-solid fa-folder-open fa-2x d-block mb-2"></i> Không có dữ liệu điểm danh phù hợp.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>