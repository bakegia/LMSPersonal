@model LMSfinal.Models.EF.Lesson
@{
    ViewData["Title"] = "Thêm bài học mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Tạo bài học mới</h5>
            </div>
            <div class="card-body">
                @* Lưu ý: Thêm Validation Summary để dễ debug lỗi nếu không lưu được *@
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <form asp-area="Instructor" asp-action="Create" method="post" enctype="multipart/form-data">
                    @* Bind SectionId từ ViewBag *@
                    <input type="hidden" name="SectionId" value="@ViewBag.SectionId" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold">Tiêu đề bài học</label>
                        <input asp-for="Title" class="form-control" placeholder="Ví dụ: Bài 1: Tổng quan về ASP.NET Core" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Order" class="form-label fw-bold">Thứ tự</label>
                            <input asp-for="Order" class="form-control" type="number" />
                            <span asp-validation-for="Order" class="text-danger"></span>
                        </div>
                        @* <div class="col-md-6">
                            <label asp-for="VideoUrl" class="form-label fw-bold">Video URL (Youtube/Drive)</label>
                            <input asp-for="VideoUrl" class="form-control" placeholder="https://..." />
                        </div> *@
                    </div>

                    <div class="mb-3">
                        <label asp-for="VideoUpload" class="form-label fw-bold">Hoặc Tải video lên</label>
                        <input asp-for="VideoUpload" type="file" class="form-control" accept="video/*" />
                        <small class="text-muted">Định dạng hỗ trợ: MP4, WebM. Dung lượng tối đa: 50MB</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label fw-bold">Nội dung bài học (Mô tả)</label>
                        <textarea asp-for="Content" class="form-control" rows="6" id="editor"></textarea>
                    </div>

                    <div class="d-flex justify-content-between pt-3 border-top">
                        <a href="javascript:history.back()" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fa-solid fa-floppy-disk me-1"></i> Lưu bài học
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* Thêm bộ thư viện Validation của jQuery để báo lỗi ngay tại client *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}