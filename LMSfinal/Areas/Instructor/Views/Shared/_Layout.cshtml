@using LMSfinal.Data
@using LMSfinal.Models.EF
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var topAvatarUrl = "~/images/avatars/default-avatar.png";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS Instructor</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/instructor-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/lms-shared.css" asp-append-version="true" />
</head>
<body>

    <div id="page-loader">
        <div class="spinner-border text-primary"></div>
    </div>

    <!-- Sidebar -->
    <aside class="sidebar-instructor">

        <div class="sidebar-header">
            <strong>INSTRUCTOR</strong>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="avatar-box">
                    @{
                        var avatarUrl = "~/images/avatars/default-avatar.png";
                        var currentUser = await UserManager.GetUserAsync(User);

                        if (currentUser?.Avatar != null)
                            avatarUrl = currentUser.Avatar;
                    }

                    <img src="@avatarUrl"
                         class="rounded-circle" />

                    <div class="user-name">
                        @User.Identity.Name
                    </div>
                </div>
            }
        </div>

        <nav class="sidebar-nav">

            <a asp-area="Instructor"
               asp-controller="HomeInstructor"
               asp-action="Index"
               class="sidebar-link @(controller == "HomeInstructor" ? "active" : "")">
                <i class="fa-solid fa-house"></i>
                Dashboard
            </a>
            <a asp-area="Instructor"
               asp-controller="Notification"
               asp-action="Index"
               class="sidebar-link @(controller == "Notification" ? "active" : "")">
                <i class="fa-solid fa-bell"></i>
                Thông báo
            </a>

            <a asp-area="Instructor"
               asp-controller="Classroom"
               asp-action="Index"
               class="sidebar-link @(controller == "Classroom" ? "active" : "")">
                <i class="fa-solid fa-chalkboard-user"></i>
                Lớp dạy của tôi
            </a>

            <a asp-area="Instructor"
               asp-controller="Quiz"
               asp-action="Index"
               class="sidebar-link @(controller == "Quiz" ? "active" : "")">
                <i class="fa-solid fa-question-circle"></i>
                Quản lý Quiz
            </a>

            <a asp-area="Instructor"
               asp-controller="ScheduleTeach"
               asp-action="Index"
               class="sidebar-link @(controller == "ScheduleTeach" ? "active" : "")">
                <i class="fa-solid fa-calendar"></i>
                Thời khóa biểu
            </a>

            <a asp-area="Instructor"
               asp-controller="Assignment"
               asp-action="Index"
               class="sidebar-link @(controller == "Assignment" ? "active" : "")">
                <i class="fa-solid fa-file-lines"></i>
                Bài tập
            </a>
            <a asp-area="Instructor"
               asp-controller="Score"
               asp-action="Index"
               class="sidebar-link @(controller == "Score" ? "active" : "")">
                <i class="fa-solid fa-file-lines"></i>
                Điểm số
            </a>

            <hr />

            <a asp-area="Instructor"
               asp-controller="Profile"
               asp-action="Index"
               class="sidebar-link">
                <i class="fa-solid fa-user"></i>
                Hồ sơ
            </a>

            <a asp-area="Admin"
               asp-controller="Account"
               asp-action="Logout"
               class="sidebar-link text-danger">
                <i class="fa-solid fa-right-from-bracket"></i>
                Đăng xuất
            </a>

        </nav>

    </aside>

    <!-- Content -->
    <div class="main-wrapper">

        <!-- Header -->
        <header class="main-header">

            <h5 class="page-title">
                @ViewData["Title"]
            </h5>

            <div class="user-info">

                <img src="@topAvatarUrl"
                     class="rounded-circle header-avatar" />

                <span>
                    Xin chào, @User.Identity?.Name
                </span>

            </div>

        </header>

        <!-- Chỉ phần này scroll -->
        <main class="main-content">
            @RenderBody()
        </main>

    </div>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const sidebar = document.querySelector(".sidebar-instructor");

            if (!sidebar) return;

            // Khôi phục vị trí scroll
            const savedPosition = sessionStorage.getItem("sidebarScroll");

            if (savedPosition) {
                sidebar.scrollTop = parseInt(savedPosition);
            }

            // Lưu vị trí scroll
            sidebar.addEventListener("scroll", function () {
                sessionStorage.setItem(
                    "sidebarScroll",
                    sidebar.scrollTop
                );
            });

        });
    </script>
    <script>
        document.querySelectorAll(".sidebar-link").forEach(link => {

            link.addEventListener("click", function () {

                const sidebar =
                    document.querySelector(".sidebar-student");

                sessionStorage.setItem(
                    "sidebarScroll",
                    sidebar.scrollTop
                );

            });

        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
